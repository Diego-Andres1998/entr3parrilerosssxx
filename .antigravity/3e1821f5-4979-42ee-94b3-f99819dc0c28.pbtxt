          text: "                  <button"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    onClick={() => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      // Generate and download a CSV representation of the report"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const headers = [\"Mes\", \"Ingresos Totales\", \"Pedidos Despachados\", \"Ticket Promedio\", \"Monto Carnes \360\237\245\251\", \"Monto Abarrotes \360\237\252\265\\n\"];"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const rows = monthlyReport.map(r => ["
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.month,"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.total.toString(),"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.orders_count.toString(),"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.average_ticket.toString(),"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.shares.carne.toString(),"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        r.shares.abarrotes.toString()"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      ].join(\",\"));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const csvContent = \"data:text/csv;charset=utf-8,\" + headers.join(\",\") + rows.join(\"\\n\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const encodedUri = encodeURI(csvContent);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const link = document.createElement(\"a\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      link.setAttribute(\"href\", encodedUri);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      link.setAttribute(\"download\", \"Reporte_Mensual_Ventas_EntreParrilleros.csv\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      document.body.appendChild(link);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      link.click();"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      document.body.removeChild(link);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    }}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
