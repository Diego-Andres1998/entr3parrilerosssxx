          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const encodedUri = encodeURI(csvContent);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      const link = document.createElement(\"a\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      link.setAttribute(\"href\", encodedUri);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      link.setAttribute(\"download\", \"Reporte_Mensual_Ventas_EntreParrilleros.csv\");"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      document.body.appendChild(link);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
