      target_content: "          {/* Laragon Simulator Panel (Right) */}\n          <div className=\"lg:col-span-4 space-y-6\">\n            <div className=\"bg-neutral-900/40 border border-neutral-900 rounded-2xl p-6 relative overflow-hidden\">\n              <div className=\"absolute top-0 right-0 p-3 opacity-5 pointer-events-none\">\n                <Database className=\"w-24 h-24 text-amber-500\" />\n              </div>\n\n              <h3 className=\"text-md font-bold text-neutral-100 flex items-center gap-2 mb-4\">\n                <Database className=\"w-5 h-5 text-amber-500 animate-pulse\" /> Laragon MySQL Simulator\n              </h3>\n              \n              <p className=\"text-neutral-500 text-xs leading-relaxed mb-6\">\n                <strong>\302\277Quieres ver la velocidad en segundos?</strong> Simula la inserci\303\263n de una transacci\303\263n hist\303\263rica de compras directamente en Laragon. Los clasificadores paralelos se volver\303\241n a entrenar y el gr\303\241fico Plotly de la izquierda se actualizar\303\241 instant\303\241neamente.\n              </p>\n\n              {simSuccess && (\n                <div className=\"p-3 mb-4 bg-green-950/40 border border-green-800/40 rounded-lg text-green-400 text-xs font-mono\">\n                  \342\234\224 \302\241Registro guardado! M\303\251tricas actualizadas en 0.82 segundos.\n                </div>\n              )}\n\n              <form onSubmit={handleSimulateInsert} className=\"space-y-4\">\n                <div>\n                  <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">Nombre del Cliente</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={simName}\n                    onChange={e => setSimName(e.target.value)}\n                    placeholder=\"Ej. Alexis S\303\241nchez\"\n                    className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none focus:border-amber-600 outline-none\"\n                    id=\"sim-name\"\n                  />\n                </div>\n\n                <div>\n                  <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">Email</label>\n                  <input\n                    type=\"email\"\n                    required\n                    value={simEmail}\n                    onChange={e => setSimEmail(e.target.value)}\n                    placeholder=\"Ej. alexis@maravilla.com\"\n                    className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none focus:border-amber-600 outline-none\"\n                  />\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-4\">\n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">Monto Gasto CLP</label>\n                    <input\n                      type=\"number\"\n                      required\n                      value={simSpending}\n                      onChange={e => setSimSpending(e.target.value)}\n                      className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none focus:border-amber-600\"\n                    />\n                  </div>\n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">Visitas Mensuales</label>\n                    <input\n                      type=\"number\"\n                      required\n                      value={simVisits}\n                      onChange={e => setSimVisits(e.target.value)}\n                      class=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none focus:border-amber-600\"\n                    />\n                  </div>\n                </div>\n\n                <div>\n                  <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">Sucursal de Origen</label>\n                  <select\n                    value={simBranch}\n                    onChange={e => setSimBranch(e.target.value)}\n                    className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none focus:border-amber-600\"\n                  >\n                    <option value=\"Osorno Centro\">Osorno Centro</option>\n                    <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                    <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                  </select>\n                </div>\n\n                <div className=\"flex items-center gap-2 py-2\">\n                  <input\n                    type=\"checkbox\"\n                    id=\"sim-is-fuga\"\n                    checked={simIsFuga}\n                    onChange={e => setSimIsFuga(e.target.checked)}\n                    className=\"w-4 h-4 rounded bg-neutral-950 accent-red-600 border border-neutral-800 focus:outline-none\"\n                  />\n                  <label htmlFor=\"sim-is-fuga\" className=\"text-xs text-neutral-400 select-none\">\n                    Forzar Estado de <span className=\"text-red-400 font-bold\">Fuga (Churn)</span>\n                  </label>\n                </div>\n\n                <button\n                  type=\"submit\"\n                  disabled={isSimulating}\n                  className=\"w-full bg-amber-600 hover:bg-amber-500 disabled:bg-neutral-850 text-neutral-950 font-bold py-2.5 px-4 rounded-lg text-xs flex items-center justify-center gap-2 transition active:scale-95 uppercase tracking-wider\"\n                  id=\"btn-simulate-laragon\"\n                >\n                  {isSimulating ? \"Registrando en MariaDB/SQL...\" : \"Insertar en Laragon y Recalcular\"}\n                </button>\n              </form>\n            </div>\n\n            {/* Quick guide card */}\n            <div className=\"bg-neutral-900/10 border border-neutral-900 rounded-xl p-5 text-xs text-neutral-400\">\n              <h4 className=\"font-bold text-neutral-200 mb-2 flex items-center gap-1.5\">\n                <HelpCircle className=\"w-4 h-4 text-amber-500\" /> Ayuda Laragon Local\n              </h4>\n              <p className=\"leading-relaxed\">\n                Nuestra app est\303\241 preparada para buscar un puerto MySQL local. Si deseas ejecutarla offline en tu laptop conectada a HeidiSQL, solo debes clonar este repositorio y levantar el servidor mediante NPM.\n                Las consultas SQL con <code>JOIN</code> se encargar\303\241n del resto.\n              </p>\n            </div>\n          </div>"
      replacement_content: "          {/* Laragon Simulator Panel (Right) */}\n          <div className=\"lg:col-span-4 space-y-6\">\n            <div className=\"bg-[#161616] border border-white/10 rounded-none p-6 relative overflow-hidden\">\n              <div className=\"absolute top-0 right-0 p-3 opacity-5 pointer-events-none\">\n                <Database className=\"w-24 h-24 text-[#b91c1c]\" />\n              </div>\n\n              <h3 className=\"text-md font-serif italic text-white flex items-center gap-2 mb-4\">\n                <Database className=\"w-5 h-5 text-[#b91c1c] animate-pulse\" /> Laragon MySQL Simulator\n              </h3>\n              \n              <p className=\"text-zinc-550 text-xs leading-relaxed mb-6 font-semibold\">\n                <strong>\302\277Quieres ver la velocidad en segundos?</strong> Simula la inserci\303\263n de una transacci\303\263n hist\303\263rica de compras directamente en Laragon. Los clasificadores paralelos se volver\303\241n a entrenar y el gr\303\241fico Plotly de la izquierda se actualizar\303\241 instant\303\241neamente.\n              </p>\n\n              {simSuccess && (\n                <div className=\"p-3 mb-4 bg-green-950/20 border border-green-800/30 text-green-400 text-xs font-mono rounded-none\">\n                  \342\234\224 \302\241Registro guardado! M\303\251tricas actualizadas en 0.82 segundos.\n                </div>\n              )}\n\n              <form onSubmit={handleSimulateInsert} className=\"space-y-4\">\n                <div>\n                  <label className=\"block text-[9px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Nombre del Cliente</label>\n                  <input\n                    type=\"text\"\n                    required\n                    value={simName}\n                    onChange={e => setSimName(e.target.value)}\n                    placeholder=\"Ej. Alexis S\303\241nchez\"\n                    className=\"w-full bg-[#121212] border border-white/10 rounded-none px-3 py-2.5 text-xs text-white outline-none focus:border-[#b91c1c]\"\n                    id=\"sim-name\"\n                  />\n                </div>\n\n                <div>\n                  <label className=\"block text-[9px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Email</label>\n                  <input\n                    type=\"email\"\n                    required\n                    value={simEmail}\n                    onChange={e => setSimEmail(e.target.value)}\n                    placeholder=\"Ej. alexis@maravilla.com\"\n                    className=\"w-full bg-[#121212] border border-white/10 rounded-none px-3 py-2.5 text-xs text-white outline-none focus:border-[#b91c1c]\"\n                  />\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-4\">\n                  <div>\n                    <label className=\"block text-[9px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Monto Gasto CLP</label>\n                    <input\n                      type=\"number\"\n                      required\n                      value={simSpending}\n                      onChange={e => setSimSpending(e.target.value)}\n                      className=\"w-full bg-[#121212] border border-white/10 rounded-none px-3 py-2.5 text-xs text-white outline-none focus:border-[#b91c1c]\"\n                    />\n                  </div>\n                  <div>\n                    <label className=\"block text-[9px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Visitas Mensuales</label>\n                    <input\n                      type=\"number\"\n                      required\n                      value={simVisits}\n                      onChange={e => setSimVisits(e.target.value)}\n                      className=\"w-full bg-[#121212] border border-white/10 rounded-none px-3 py-2.5 text-xs text-white outline-none focus:border-[#b91c1c]\"\n                    />\n                  </div>\n                </div>\n\n                <div>\n                  <label className=\"block text-[9px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Sucursal de Origen</label>\n                  <select\n                    value={simBranch}\n                    onChange={e => setSimBranch(e.target.value)}\n                    className=\"w-full bg-[#121212] border border-white/10 rounded-none px-3 py-2.5 text-xs text-white outline-none focus:border-[#b91c1c]\"\n                  >\n                    <option value=\"Osorno Centro\">Osorno Centro</option>\n                    <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                    <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                  </select>\n                </div>\n\n                <div className=\"flex items-center gap-2 py-2\">\n                  <input\n                    type=\"checkbox\"\n                    id=\"sim-is-fuga\"\n                    checked={simIsFuga}\n                    onChange={e => setSimIsFuga(e.target.checked)}\n                    className=\"w-4 h-4 rounded-none bg-[#121212] accent-red-650 border border-white/10 focus:outline-none\"\n                  />\n                  <label htmlFor=\"sim-is-fuga\" className=\"text-xs text-zinc-400 select-none font-semibold\">\n                    Forzar Estado de <span className=\"text-[#b91c1c] font-bold\">Fuga (Churn)</span>\n                  </label>\n                </div>\n\n                <button\n                  type=\"submit\"\n                  disabled={isSimulating}\n                  className=\"w-full bg-[#b91c1c] hover:bg-red-700 disabled:bg-zinc-850 text-white font-bold py-3 px-4 rounded-none text-[10px] flex items-center justify-center gap-2 transition active:scale-95 uppercase tracking-widest font-mono cursor-pointer\"\n                  id=\"btn-simulate-laragon\"\n                >\n                  {isSimulating ? \"Registrando en MariaDB/SQL...\" : \"Insertar en Laragon y Recalcular\"}\n                </button>\n              </form>\n            </div>\n\n            {/* Quick guide card */}\n            <div className=\"bg-[#161616]/40 border border-white/10 rounded-none p-5 text-xs text-zinc-450 leading-relaxed space-y-2\">\n              <h4 className=\"font-serif italic text-white flex items-center gap-1.5 text-sm\">\n                <HelpCircle className=\"w-4 h-4 text-[#b91c1c]\" /> Ayuda Laragon Local\n              </h4>\n              <p className=\"font-semibold\">\n                Nuestra app est\303\241 preparada para buscar un puerto MySQL local. Si deseas ejecutarla offline en tu laptop conectada a HeidiSQL, solo debes clonar este repositorio y levantar el servidor mediante NPM.\n                Las consultas SQL con <code>JOIN</code> se encargar\303\241n del resto.\n              </p>\n            </div>\n          </div>"
    }
