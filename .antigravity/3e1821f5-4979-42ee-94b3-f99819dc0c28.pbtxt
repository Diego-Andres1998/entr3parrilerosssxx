  file_change {
    absolute_path_uri: "file:///server/sheets.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { Order } from \"./db\";\n\nexport interface SheetsSyncStatus {\n  synced: boolean;\n  simulated: boolean;\n  message: string;\n  sheetId: string;\n  addedRowsCount: number;\n}\n\n// Configurable Sheet ID\nlet ACTIVE_SPREADSHEET_ID = process.env.GOOGLE_SHEETS_ID || \"1Y8gYp99G152P7Fv6ZzY_zH7pYshWJ5f7H-8f7Z-example\";\nlet GOOGLE_CLIENT_CONNECTED = false;\n\nexport function getSheetsConfig() {\n  return {\n    sheetId: ACTIVE_SPREADSHEET_ID,\n    connected: GOOGLE_CLIENT_CONNECTED\n  };\n}\n\nexport function updateSheetsConfig(sheetId: string) {\n  if (sheetId) {\n    ACTIVE_SPREADSHEET_ID = sheetId;\n    return true;\n  }\n  return false;\n}\n\nexport async function appendOrderToSheet(order: Order, oauthToken?: string): Promise<SheetsSyncStatus> {\n  const formattedItems = order.items.map(i => `${i.name} (x${i.quantity})`).join(\", \");\n  const rowData = [\n    order.id.toString(),\n    new Date(order.created_at).toLocaleString(\"es-CL\"),\n    order.customer_name,\n    order.email,\n    order.phone,\n    order.branch,\n    formattedItems,\n    order.total_amount.toString(),\n    order.status\n  ];\n\n  if (oauthToken) {\n    try {\n      // Real API request to Google Sheets Append API\n      const url = `https://sheets.googleapis.com/v4/spreadsheets/${ACTIVE_SPREADSHEET_ID}/values/A1:append?valueInputOption=USER_ENTERED`;\n      const response = await fetch(url, {\n        method: \"POST\",\n        headers: {\n          \"Authorization\": `Bearer ${oauthToken}`,\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify({\n          values: [rowData]\n        })\n      });\n\n      if (response.ok) {\n        console.log(`\360\237\223\212 Successfully synchronized order #${order.id} with Google Sheets!`);\n        GOOGLE_CLIENT_CONNECTED = true;\n        return {\n          synced: true,\n          simulated: false,\n          message: \"Sincronizado correctamente con tu Google Sheets en tiempo real.\",\n          sheetId: ACTIVE_SPREADSHEET_ID,\n          addedRowsCount: 1\n        };\n      } else {\n        const errText = await response.text();\n        throw new Error(errText);\n      }\n    } catch (err: any) {\n      console.warn(\"\342\232\240\357\270\217 Google Sheets API error, falling back to simulated integration:\", err.message);\n      return {\n        synced: false,\n        simulated: true,\n        message: `Fallo de autorizaci\303\263n al escribir API de Sheets: ${err.message}. Operando en modo de simulaci\303\263n.`,\n        sheetId: ACTIVE_SPREADSHEET_ID,\n        addedRowsCount: 1\n      };\n    }\n  }\n\n  // Fallback simulator is active\n  console.log(`\360\237\223\212 [SIMULACI\303\223N GOOGLE SHEETS] Append Row a planilla ID \'${ACTIVE_SPREADSHEET_ID}\':`, rowData);\n  return {\n    synced: false,\n    simulated: true,\n    message: \"Pedido guardado y listo para sincronizar. (Conecta con Google Sheets haciendo clic en el panel para otorgar permisos OAuth o configurar tu ID de planilla).\",\n    sheetId: ACTIVE_SPREADSHEET_ID,\n    addedRowsCount: 1\n  };\n}\n\nexport async function syncAllOrdersToSheet(orders: Order[], oauthToken?: string): Promise<SheetsSyncStatus> {\n  if (oauthToken) {\n    try {\n      const url = `https://sheets.googleapis.com/v4/spreadsheets/${ACTIVE_SPREADSHEET_ID}/values/A1:append?valueInputOption=USER_ENTERED`;\n      \n      const values = orders.map(order => [\n        order.id.toString(),\n        new Date(order.created_at).toLocaleString(\"es-CL\"),\n        order.customer_name,\n        order.email,\n        order.phone,\n        order.branch,\n        order.items.map(i => `${i.name} (x${i.quantity})`).join(\", \"),\n        order.total_amount.toString(),\n        order.status\n      ]);\n\n      const response = await fetch(url, {\n        method: \"POST\",\n        headers: {\n          \"Authorization\": `Bearer ${oauthToken}`,\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify({ values })\n      });\n\n      if (response.ok) {\n        GOOGLE_CLIENT_CONNECTED = true;\n        return {\n          synced: true,\n          simulated: false,\n          message: `Sincronizados correctamente ${orders.length} pedidos hist\303\263ricos en tu Google Sheets.`,\n          sheetId: ACTIVE_SPREADSHEET_ID,\n          addedRowsCount: orders.length\n        };\n      } else {\n        const errorText = await response.text();\n        throw new Error(errorText);\n      }\n    } catch (err: any) {\n      return {\n        synced: false,\n        simulated: true,\n        message: `Fallo de conexi\303\263n: ${err.message}.`,\n        sheetId: ACTIVE_SPREADSHEET_ID,\n        addedRowsCount: orders.length\n      };\n    }\n  }\n\n  return {\n    synced: false,\n    simulated: true,\n    message: \"Sincronizados localmente. Para grabarlos en Sheets, logu\303\251ate con Google.\",\n    sheetId: ACTIVE_SPREADSHEET_ID,\n    addedRowsCount: orders.length\n  };\n}\n"
    }
