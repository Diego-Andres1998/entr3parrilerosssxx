        }
        lines {
          text: "              <h3 className=\"text-md font-bold text-neutral-100 flex items-center gap-2 mb-4\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <Database className=\"w-5 h-5 text-amber-500 animate-pulse\" /> Laragon MySQL Simulator"
