        }
        lines {
          text: "// =========================================="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// KNN CLASSIFIER (K = 5 neighbors)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// =========================================="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export class KNNClassifier {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  k: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  trainX: number[][] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  trainY: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  constructor(k = 5) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    this.k = k;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  fit(X: number[][], y: number[]) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    this.trainX = X;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    this.trainY = y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  predict(X_test: number[][]): number[] {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (this.trainX.length === 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return X_test.map(() => 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Normalization bounds to scale spending and visits to a 0-1 range fairly"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const spends = this.trainX.map(p => p[0]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const visits = this.trainX.map(p => p[1]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const minSpend = Math.min(...spends, 1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const maxSpend = Math.max(...spends, 100000);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const minVisits = Math.min(...visits, 1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const maxVisits = Math.max(...visits, 10);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const norm = (v: number, min: number, max: number) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return max === min ? 0 : (v - min) / (max - min);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return X_test.map(point => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Calculate distances to all training points"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const dists = this.trainX.map((trainPoint, idx) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const dSpend = norm(point[0], minSpend, maxSpend) - norm(trainPoint[0], minSpend, maxSpend);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const dVisits = norm(point[1], minVisits, maxVisits) - norm(trainPoint[1], minVisits, maxVisits);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const distance = Math.sqrt(dSpend * dSpend + dVisits * dVisits);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return { distance, label: this.trainY[idx] };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Sort by proximity"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      dists.sort((a, b) => a.distance - b.distance);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Take K neighbors (safely bounding if there aren\'t enough training points yet)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const currentK = Math.min(this.k, dists.length);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const neighbors = dists.slice(0, currentK);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const votes = neighbors.reduce((acc, n) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        acc[n.label] = (acc[n.label] || 0) + 1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        return acc;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }, {} as Record<number, number>);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return (votes[1] || 0) >= (votes[0] || 0) ? 1 : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// =========================================="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// DECISION TREE CLASSIFIER (Max Depth = 4)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// =========================================="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export interface DecisionNode {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  isLeaf: boolean;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  featureIndex?: number;  // 0 = spending, 1 = visits"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  threshold?: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  left?: DecisionNode;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  right?: DecisionNode;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  label?: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export class DecisionTreeClassifier {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  maxDepth: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  root: DecisionNode | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  constructor(maxDepth = 4) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    this.maxDepth = maxDepth;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  private calculateGini(y: number[]): number {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (y.length === 0) return 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const count1 = y.filter(val => val === 1).length;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const p1 = count1 / y.length;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const p0 = 1 - p1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return 1 - (p0 * p0 + p1 * p1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  private buildTree(X: number[][], y: number[], depth: number): DecisionNode {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const isPure = y.every(val => val === y[0]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const count1 = y.filter(val => val === 1).length;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const majorityClass = count1 >= (y.length / 2) ? 1 : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Stop constraints"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (depth >= this.maxDepth || isPure || X.length <= 2) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return { isLeaf: true, label: majorityClass };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bestGiniValue = 999;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bFeature = -1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bThreshold = -1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bLeftX: number[][] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bLeftY: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bRightX: number[][] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let bRightY: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const numFeatures = X[0].length;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let f = 0; f < numFeatures; f++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const featureVals = X.map(r => r[f]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const uniqueVals = Array.from(new Set(featureVals)).sort((a, b) => a - b);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let i = 0; i < uniqueVals.length - 1; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Splitting point as average of consecutive distinct values"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const thresh = (uniqueVals[i] + uniqueVals[i + 1]) / 2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const leftIndices: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const rightIndices: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        X.forEach((row, idx) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          if (row[f] <= thresh) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            leftIndices.push(idx);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            rightIndices.push(idx);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (leftIndices.length === 0 || rightIndices.length === 0) continue;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const leftY = leftIndices.map(idx => y[idx]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const rightY = rightIndices.map(idx => y[idx]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const splitGini = (leftY.length / y.length) * this.calculateGini(leftY) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          (rightY.length / y.length) * this.calculateGini(rightY);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (splitGini < bestGiniValue) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bestGiniValue = splitGini;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bFeature = f;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bThreshold = thresh;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bLeftX = leftIndices.map(idx => X[idx]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bLeftY = leftY;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bRightX = rightIndices.map(idx => X[idx]);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          bRightY = rightY;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Split didn\'t improve or split failed"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (bFeature === -1) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return { isLeaf: true, label: majorityClass };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      isLeaf: false,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      featureIndex: bFeature,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      threshold: bThreshold,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      left: this.buildTree(bLeftX, bLeftY, depth + 1),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      right: this.buildTree(bRightX, bRightY, depth + 1)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  fit(X: number[][], y: number[]) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (X.length === 0) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    this.root = this.buildTree(X, y, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  private predictRow(node: DecisionNode, row: number[]): number {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (node.isLeaf) return node.label!;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const val = row[node.featureIndex!];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (val <= node.threshold!) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return this.predictRow(node.left!, row);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    } else {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      return this.predictRow(node.right!, row);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  predict(X: number[][]): number[] {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
