  file_change {
    absolute_path_uri: "file:///src/components/AdminPanel.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \"react\";\nimport { Order, OrderItem, DatabaseStatus } from \"../types\";\nimport { \n  FileSpreadsheet, Mail, CheckCircle, RefreshCw, Flame, \n  Trash2, Edit, Save, PlusCircle, XCircle, ChevronRight, \n  Settings, TrendingUp, BarChart2, ShieldCheck, Download\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface AdminPanelProps {\n  orders: Order[];\n  loading: boolean;\n  dbStatus: DatabaseStatus | null;\n  refreshCounter: number;\n  triggerRefresh: () => void;\n  onUpdateOrder: (id: number, data: Partial<Order>) => Promise<boolean>;\n  onDeleteOrder: (id: number) => Promise<boolean>;\n  onAddManualOrder: (newOrder: any) => Promise<boolean>;\n}\n\nexport default function AdminPanel({\n  orders,\n  loading,\n  dbStatus,\n  refreshCounter,\n  triggerRefresh,\n  onUpdateOrder,\n  onDeleteOrder,\n  onAddManualOrder\n}: AdminPanelProps) {\n  // Navigation states inside admin panel\n  const [activePane, setActivePane] = useState<\"orders\" | \"reports\" | \"sheets\">(\"orders\");\n\n  // Orders CRUD states\n  const [editingOrderId, setEditingOrderId] = useState<number | null>(null);\n  const [editStatus, setEditStatus] = useState<any>(\"\");\n  const [editClientName, setEditClientName] = useState(\"\");\n  const [editClientPhone, setEditClientPhone] = useState(\"\");\n  const [editClientEmail, setEditClientEmail] = useState(\"\");\n  const [editBranch, setEditBranch] = useState(\"\");\n  \n  // Status filtering\n  const [statusFilter, setStatusFilter] = useState<string>(\"todos\");\n  \n  // Manual order builder states\n  const [showAddForm, setShowAddForm] = useState(false);\n  const [newCustName, setNewCustName] = useState(\"\");\n  const [newCustEmail, setNewCustEmail] = useState(\"\");\n  const [newCustPhone, setNewCustPhone] = useState(\"\");\n  const [newCustBranch, setNewCustBranch] = useState(\"Osorno Centro\");\n  const [meatQty, setMeatQty] = useState(1);\n  const [groceryQty, setGroceryQty] = useState(0);\n\n  // Sheets sync states\n  const [sheetsConfig, setSheetsConfig] = useState({ sheetId: \"\", connected: false });\n  const [syncStatusMsg, setSyncStatusMsg] = useState(\"\");\n  const [syncingAll, setSyncingAll] = useState(false);\n\n  // Monthly Sales Report state\n  const [monthlyReport, setMonthlyReport] = useState<any[]>([]);\n  const [loadingReport, setLoadingReport] = useState(false);\n\n  useEffect(() => {\n    fetchSheetsConfig();\n    fetchMonthlyReport();\n  }, [refreshCounter]);\n\n  const fetchSheetsConfig = async () => {\n    try {\n      const resp = await fetch(\"/api/sheets-config\");\n      if (resp.ok) {\n        const config = await resp.json();\n        setSheetsConfig(config);\n      }\n    } catch (e) {\n      console.error(e);\n    }\n  };\n\n  const fetchMonthlyReport = async () => {\n    setLoadingReport(true);\n    try {\n      const resp = await fetch(\"/api/monthly-sales-report\");\n      if (resp.ok) {\n        const data = await resp.json();\n        setMonthlyReport(data.summary || []);\n      }\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoadingReport(false);\n    }\n  };\n\n  // Google Sheets integration configuration update\n  const handleUpdateSheetId = async (e: React.FormEvent) => {\n    e.preventDefault();\n    try {\n      const resp = await fetch(\"/api/sheets-config\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ sheetId: sheetsConfig.sheetId })\n      });\n      if (resp.ok) {\n        setSyncStatusMsg(\"Planilla de Google Sheets actualizada con \303\251xito.\");\n        fetchSheetsConfig();\n      }\n    } catch (e) {\n      setSyncStatusMsg(\"Fallo de conexi\303\263n al actualizar.\");\n    }\n  };\n\n  // Synchronise full database records with spreadsheet manually\n  const triggerManualGroupSync = async () => {\n    setSyncingAll(true);\n    setSyncStatusMsg(\"Sincronizando registros con Google Cloud Sheets...\");\n    try {\n      const resp = await fetch(\"/api/sheets-sync-all\", { method: \"POST\" });\n      if (resp.ok) {\n        const data = await resp.json();\n        setSyncStatusMsg(`Sincronizaci\303\263n Completa. ${data.addedRowsCount} pedidos sincronizados en tiempo r\303\251cord.`);\n        fetchSheetsConfig();\n      }\n    } catch (e) {\n      setSyncStatusMsg(\"Fallo al contactar el microservicio.\");\n    } finally {\n      setSyncingAll(false);\n    }\n  };\n\n  // CRUD Actions\n  const handleStartEdit = (ord: Order) => {\n    setEditingOrderId(ord.id);\n    setEditStatus(ord.status);\n    setEditClientName(ord.customer_name);\n    setEditClientPhone(ord.phone);\n    setEditClientEmail(ord.email);\n    setEditBranch(ord.branch);\n  };\n\n  const handleSaveEdit = async (id: number) => {\n    const success = await onUpdateOrder(id, {\n      status: editStatus,\n      customer_name: editClientName,\n      phone: editClientPhone,\n      email: editClientEmail,\n      branch: editBranch\n    });\n    if (success) {\n      setEditingOrderId(null);\n      triggerRefresh();\n    } else {\n      alert(\"No se pudo actualizar el registro.\");\n    }\n  };\n\n  const handleDelete = async (id: number) => {\n    if (window.confirm(`\302\277Est\303\241s seguro de que deseas eliminar permanentemente el pedido de compra #${id} de la base de datos relacional?`)) {\n      const success = await onDeleteOrder(id);\n      if (success) {\n        triggerRefresh();\n      } else {\n        alert(\"Fallo al eliminar el pedido.\");\n      }\n    }\n  };\n\n  const handleAddManualOrder = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newCustName || !newCustEmail || !newCustPhone) {\n      alert(\"Por favor completa los datos b\303\241sicos del cliente.\");\n      return;\n    }\n\n    if (meatQty === 0 && groceryQty === 0) {\n      alert(\"Agrega al menos un producto a la cotizaci\303\263n de pedido manual.\");\n      return;\n    }\n\n    // Build customized simulated cart items\n    const manualItems: OrderItem[] = [];\n    let mathTotal = 0;\n\n    if (meatQty > 0) {\n      manualItems.push({\n        name: \"Lomo Vetado Angus Premium [Manual]\",\n        category: \"carne\",\n        quantity: meatQty,\n        price: 18990\n      });\n      mathTotal += (18990 * meatQty);\n    }\n\n    if (groceryQty > 0) {\n      manualItems.push({\n        name: \"Carb\303\263n de Espino Premium [Manual]\",\n        category: \"abarrotes\",\n        quantity: groceryQty,\n        price: 5990\n      });\n      mathTotal += (5990 * groceryQty);\n    }\n\n    const manualPayload = {\n      customer_name: newCustName,\n      email: newCustEmail,\n      phone: newCustPhone,\n      branch: newCustBranch,\n      items: manualItems,\n      total_amount: mathTotal,\n      status: \"Pendiente\"\n    };\n\n    const success = await onAddManualOrder(manualPayload);\n    if (success) {\n      setShowAddForm(false);\n      setNewCustName(\"\");\n      setNewCustEmail(\"\");\n      setNewCustPhone(\"\");\n      setMeatQty(1);\n      setGroceryQty(0);\n      triggerRefresh();\n    } else {\n      alert(\"Error al intentar insertar el pedido manual en Laragon.\");\n    }\n  };\n\n  // Direct calculation variables based on orders list state\n  const activeOrders = orders.filter(o => o.status !== \"Cancelado\");\n  const overallSales = activeOrders.reduce((sum, o) => sum + o.total_amount, 0);\n  const averageTicket = activeOrders.length > 0 ? Math.round(overallSales / activeOrders.length) : 0;\n\n  // Filter list\n  const filteredOrders = orders.filter(o => {\n    if (statusFilter === \"todos\") return true;\n    return o.status.toLowerCase() === statusFilter.toLowerCase();\n  });\n\n  return (\n    <div className=\"bg-neutral-950 text-neutral-100 min-h-screen p-4 md:p-8\">\n      <div className=\"mx-auto max-w-7xl\">\n        \n        {/* Connection health banner & Title */}\n        <div className=\"flex flex-col md:flex-row items-start md:items-center justify-between border-b border-neutral-900 pb-6 mb-8 gap-4\">\n          <div>\n            <h1 className=\"text-2xl font-bold text-neutral-100 flex items-center gap-2\">\n              <Settings className=\"text-amber-500 w-6 h-6 animate-spin-slow\" /> Panel de Negocio Entre Parrilleros\n            </h1>\n            <p className=\"text-xs text-neutral-500 mt-1 leading-relaxed\">\n              Consola de administraci\303\263n relacional. Controla pedidos, visualiza reportes autom\303\241ticos y sincroniza hojas de c\303\241lculo en la nube.\n            </p>\n          </div>\n\n          {/* Database server indicators */}\n          <div className=\"flex flex-wrap items-center gap-3\">\n            <div className=\"bg-neutral-900/85 border border-neutral-800 px-3 py-1.5 rounded-lg flex items-center gap-2 text-xs\">\n              <span className={`w-2.5 h-2.5 rounded-full ${dbStatus?.connected ? \"bg-green-500 animate-pulse\" : \"bg-yellow-500\"}`} />\n              <span className=\"font-mono text-[10px] text-neutral-300\">\n                Laragon Port 3306: {dbStatus?.connected ? \"ONLINE\" : \"OFFLINE FALLBACK\"}\n              </span>\n            </div>\n            \n            <button\n              onClick={triggerRefresh}\n              className=\"bg-neutral-800 hover:bg-neutral-700 text-neutral-300 border border-neutral-700/60 px-3 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1.5 transition\"\n            >\n              <RefreshCw className=\"w-3.5 h-3.5\" /> Forzar Refresco\n            </button>\n          </div>\n        </div>\n\n        {/* Executive Quick Stats Cards */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8\">\n          \n          <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-5 flex items-start justify-between\">\n            <div>\n              <span className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-500 font-mono\">Ingresos Netos del Mes</span>\n              <h3 className=\"text-xl font-bold font-mono text-amber-500 mt-1\">${overallSales.toLocaleString(\"es-CL\")}</h3>\n              <p className=\"text-[10px] text-neutral-500 mt-0.5\">Excluye compras canceladas</p>\n            </div>\n            <span className=\"text-2xl\">\360\237\222\260</span>\n          </div>\n\n          <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-5 flex items-start justify-between\">\n            <div>\n              <span className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-500 font-mono\">Pedidos Registrados</span>\n              <h3 className=\"text-xl font-bold font-mono text-neutral-100 mt-1\">{orders.length} \303\263rdenes</h3>\n              <p className=\"text-[10px] text-neutral-500 mt-0.5\">Registros locales en \"parrillero\"</p>\n            </div>\n            <span className=\"text-2xl\">\360\237\223\213</span>\n          </div>\n\n          <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-5 flex items-start justify-between\">\n            <div>\n              <span className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-500 font-mono\">Ticket Promedio Asado</span>\n              <h3 className=\"text-xl font-bold font-mono text-neutral-100 mt-1\">${averageTicket.toLocaleString(\"es-CL\")}</h3>\n              <p className=\"text-[10px] text-neutral-500 mt-0.5\">Monto medio consumido</p>\n            </div>\n            <span className=\"text-2xl\">\360\237\245\251</span>\n          </div>\n\n          <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-5 flex items-start justify-between\">\n            <div>\n              <span className=\"text-[10px] font-bold uppercase tracking-wider text-neutral-500 font-mono\">Sheets Auto Sync</span>\n              <h3 className=\"text-xs font-bold text-green-400 mt-2 flex items-center gap-1\">\n                <CheckCircle className=\"w-4.5 h-4.5 text-green-500\" /> Sincronizaci\303\263n Lista\n              </h3>\n              <p className=\"text-[9px] text-neutral-500 mt-1 truncate max-w-[160px]\">ID: {sheetsConfig.sheetId.slice(0, 8)}...</p>\n            </div>\n            <span className=\"text-2xl\">\360\237\223\212</span>\n          </div>\n\n        </div>\n\n        {/* Administration navigation subtabs */}\n        <div className=\"flex border-b border-neutral-900 mb-8 overflow-x-auto gap-2\">\n          <button\n            onClick={() => setActivePane(\"orders\")}\n            className={`px-4 py-2.5 font-semibold text-xs border-b-2 transition-all flex items-center gap-2 ${\n              activePane === \"orders\" ? \"border-amber-500 text-amber-500 font-bold\" : \"border-transparent text-neutral-400 hover:text-neutral-200\"\n            }`}\n            id=\"admin-pane-orders\"\n          >\n            Gesti\303\263n de Pedidos & CRUD\n          </button>\n          <button\n            onClick={() => setActivePane(\"reports\")}\n            className={`px-4 py-2.5 font-semibold text-xs border-b-2 transition-all flex items-center gap-2 ${\n              activePane === \"reports\" ? \"border-amber-500 text-amber-500 font-bold\" : \"border-transparent text-neutral-400 hover:text-neutral-200\"\n            }`}\n            id=\"admin-pane-reports\"\n          >\n            Reportes Mensuales Autom\303\241ticos\n          </button>\n          <button\n            onClick={() => setActivePane(\"sheets\")}\n            className={`px-4 py-2.5 font-semibold text-xs border-b-2 transition-all flex items-center gap-2 ${\n              activePane === \"sheets\" ? \"border-amber-500 text-amber-500 font-bold\" : \"border-transparent text-neutral-400 hover:text-neutral-200\"\n            }`}\n            id=\"admin-pane-sheets\"\n          >\n            Conexi\303\263n Google Sheets\n          </button>\n        </div>\n\n        {/* Main Content Pane switch */}\n        <div>\n          \n          {/* ORDERS CRUD PANE */}\n          {activePane === \"orders\" && (\n            <div className=\"space-y-6\">\n              \n              {/* Toolbar */}\n              <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-2\">\n                \n                {/* Filter status buttons */}\n                <div className=\"flex flex-wrap items-center gap-1.5 bg-neutral-900 border border-neutral-800 p-1 rounded-lg\">\n                  {([\"todos\", \"pendiente\", \"preparando\", \"entregado\", \"cancelado\"] as const).map(status => (\n                    <button\n                      key={status}\n                      onClick={() => setStatusFilter(status)}\n                      className={`px-3 py-1 rounded text-xs capitalize ${\n                        statusFilter === status \n                          ? \"bg-amber-600 text-neutral-950 font-bold\" \n                          : \"text-neutral-400 hover:text-neutral-200\"\n                      }`}\n                      id={`filter-btn-${status}`}\n                    >\n                      {status}\n                    </button>\n                  ))}\n                </div>\n\n                {/* Add Manual Order Button */}\n                <button\n                  onClick={() => setShowAddForm(!showAddForm)}\n                  className=\"bg-amber-600 hover:bg-amber-500 text-neutral-950 font-extrabold text-xs px-4 py-2 rounded-lg flex items-center gap-2 transition active:scale-95 select-none\"\n                  id=\"add-manual-order-trigger\"\n                >\n                  <PlusCircle className=\"w-4 h-4\" /> {showAddForm ? \"Cerrar Cotizador\" : \"Registrar Pedido F\303\255sico / Tel\303\251fono\"}\n                </button>\n              </div>\n\n              {/* Add Manual Order Form dialog drawer */}\n              <AnimatePresence>\n                {showAddForm && (\n                  <motion.div\n                    initial={{ opacity: 0, height: 0 }}\n                    animate={{ opacity: 1, height: \"auto\" }}\n                    exit={{ opacity: 0, height: 0 }}\n                    className=\"overflow-hidden bg-neutral-900/20 border border-neutral-900 rounded-2xl p-6\"\n                  >\n                    <h3 className=\"text-sm font-bold uppercase tracking-wider text-neutral-200 mb-4 border-b border-neutral-900 pb-3\">\n                      Ingreso Manual de Pedido (Laragon CRUD)\n                    </h3>\n                    \n                    <form onSubmit={handleAddManualOrder} className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                      <div className=\"space-y-4\">\n                        <h4 className=\"text-xs font-bold text-amber-500 font-mono\">1. Datos del Cliente</h4>\n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Nombre</label>\n                          <input\n                            type=\"text\"\n                            required\n                            placeholder=\"Ej. Francisca Edwards\"\n                            value={newCustName}\n                            onChange={e => setNewCustName(e.target.value)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none\"\n                            id=\"manual-customer-name\"\n                          />\n                        </div>\n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Email</label>\n                          <input\n                            type=\"email\"\n                            required\n                            placeholder=\"Ej. fran.e@gmail.com\"\n                            value={newCustEmail}\n                            onChange={e => setNewCustEmail(e.target.value)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none\"\n                          />\n                        </div>\n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">WhatsApp</label>\n                          <input\n                            type=\"text\"\n                            required\n                            placeholder=\"Ej. +5699991234\"\n                            value={newCustPhone}\n                            onChange={e => setNewCustPhone(e.target.value)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none\"\n                          />\n                        </div>\n                      </div>\n\n                      <div className=\"space-y-4\">\n                        <h4 className=\"text-xs font-bold text-amber-500 font-mono\">2. Detalle de Compra</h4>\n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Asociar Sucursal</label>\n                          <select\n                            value={newCustBranch}\n                            onChange={e => setNewCustBranch(e.target.value)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none\"\n                          >\n                            <option value=\"Osorno Centro\">Osorno Centro</option>\n                            <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                            <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                          </select>\n                        </div>\n                        \n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Cortes de Lomo Vetado (Cant.)</label>\n                          <input\n                            type=\"number\"\n                            min=\"0\"\n                            value={meatQty}\n                            onChange={e => setMeatQty(parseInt(e.target.value, 10) || 0)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none font-mono\"\n                          />\n                        </div>\n\n                        <div>\n                          <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Bolsas Carb\303\263n de Espino (Cant.)</label>\n                          <input\n                            type=\"number\"\n                            min=\"0\"\n                            value={groceryQty}\n                            onChange={e => setGroceryQty(parseInt(e.target.value, 10) || 0)}\n                            className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-1.5 text-xs focus:border-amber-600 outline-none font-mono\"\n                          />\n                        </div>\n                      </div>\n\n                      <div className=\"space-y-4 flex flex-col justify-between\">\n                        <h4 className=\"text-xs font-bold text-amber-500 font-mono\">3. Cotizaci\303\263n Relacional</h4>\n                        \n                        <div className=\"bg-neutral-950 border border-neutral-900 rounded-lg p-4 space-y-2 text-xs\">\n                          <div className=\"flex items-center justify-between text-neutral-500 font-mono\">\n                            <span>Lomo Angus:</span>\n                            <span>${(meatQty * 18990).toLocaleString(\"es-CL\")}</span>\n                          </div>\n                          <div className=\"flex items-center justify-between text-neutral-500 font-mono\">\n                            <span>Carb\303\263n Espino:</span>\n                            <span>${(groceryQty * 5990).toLocaleString(\"es-CL\")}</span>\n                          </div>\n                          <hr className=\"border-neutral-900\" />\n                          <div className=\"flex items-center justify-between text-neutral-200 font-bold font-mono\">\n                            <span>TOTAL COTIZADO:</span>\n                            <span className=\"text-amber-500 text-sm\">${((meatQty * 18990) + (groceryQty * 5990)).toLocaleString(\"es-CL\")}</span>\n                          </div>\n                        </div>\n\n                        <button\n                          type=\"submit\"\n                          className=\"w-full bg-amber-600 hover:bg-amber-500 text-neutral-950 font-bold py-2 px-4 rounded-lg text-xs transition uppercase font-mono tracking-wider active:scale-95\"\n                          id=\"submit-manual-order\"\n                        >\n                          Grabar Pedido en DB Laragon\n                        </button>\n                      </div>\n                    </form>\n                  </motion.div>\n                )}\n              </AnimatePresence>\n\n              {/* Orders table list */}\n              <div className=\"bg-neutral-900/20 border border-neutral-900 rounded-2xl overflow-hidden\">\n                {loading ? (\n                  <div className=\"py-20 text-center text-neutral-500 text-xs font-mono select-none\">\n                    <RefreshCw className=\"w-6 h-6 animate-spin text-amber-500 mx-auto mb-2\" />\n                    Cargando pedidos de la base de datos...\n                  </div>\n                ) : filteredOrders.length === 0 ? (\n                  <div className=\"py-20 text-center text-neutral-500 text-xs select-none\">\n                    No se encontraron pedidos vigentes para el criterio seleccionado.\n                  </div>\n                ) : (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-left text-xs border-collapse\">\n                      <thead>\n                        <tr className=\"bg-neutral-900/60 font-mono text-[10px] text-neutral-400 uppercase border-b border-neutral-800\">\n                          <th className=\"p-4 w-12 text-center\">ID</th>\n                          <th className=\"p-4\">Cliente</th>\n                          <th className=\"p-4\">Sucursal</th>\n                          <th className=\"p-4\">Contenido Pedido</th>\n                          <th className=\"p-4 text-right\">Compra Total</th>\n                          <th className=\"p-4 text-center\">Fecha Pedido</th>\n                          <th className=\"p-4 text-center\">Estado</th>\n                          <th className=\"p-4 text-center\">Acciones CRUD</th>\n                        </tr>\n                      </thead>\n                      <tbody>\n                        {filteredOrders.map(order => {\n                          const isEditing = editingOrderId === order.id;\n                          return (\n                            <tr key={order.id} className=\"border-b border-neutral-900 hover:bg-neutral-900/10\">\n                              <td className=\"p-4 font-mono font-bold text-neutral-500 text-center\">\n                                #{order.id}\n                              </td>\n                              \n                              <td className=\"p-4\">\n                                {isEditing ? (\n                                  <div className=\"space-y-2\">\n                                    <input\n                                      type=\"text\"\n                                      value={editClientName}\n                                      onChange={e => setEditClientName(e.target.value)}\n                                      className=\"bg-neutral-950 border border-neutral-800 rounded px-2 py-1 text-xs w-full text-white\"\n                                    />\n                                    <input\n                                      type=\"email\"\n                                      value={editClientEmail}\n                                      onChange={e => setEditClientEmail(e.target.value)}\n                                      className=\"bg-neutral-950 border border-neutral-800 rounded px-2 py-0.5 text-[10px] w-full text-neutral-400\"\n                                    />\n                                    <input\n                                      type=\"text\"\n                                      value={editClientPhone}\n                                      onChange={e => setEditClientPhone(e.target.value)}\n                                      className=\"bg-neutral-950 border border-neutral-800 rounded px-2 py-0.5 text-[10px] w-full text-neutral-400\"\n                                    />\n                                  </div>\n                                ) : (\n                                  <div>\n                                    <h4 className=\"font-bold text-neutral-200\">{order.customer_name}</h4>\n                                    <p className=\"text-[10px] text-neutral-500 font-mono mt-0.5\">{order.email}</p>\n                                    <p className=\"text-[10px] text-neutral-500 font-mono\">{order.phone}</p>\n                                  </div>\n                                )}\n                              </td>\n\n                              <td className=\"p-4\">\n                                {isEditing ? (\n                                  <select\n                                    value={editBranch}\n                                    onChange={e => setEditBranch(e.target.value)}\n                                    className=\"bg-neutral-950 border border-neutral-800 rounded px-2 py-1 text-xs text-white\"\n                                  >\n                                    <option value=\"Osorno Centro\">Osorno Centro</option>\n                                    <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                                    <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                                  </select>\n                                ) : (\n                                  <span className=\"bg-red-950/20 text-red-400 border border-red-900/30 px-2 py-0.5 rounded text-[10px] font-semibold font-mono\">\n                                    {order.branch}\n                                  </span>\n                                )}\n                              </td>\n\n                              <td className=\"p-4 max-w-xs\">\n                                <div className=\"space-y-1\">\n                                  {order.items.map((it, i) => (\n                                    <div key={i} className=\"flex items-center justify-between text-[11px] text-neutral-400 leading-tight\">\n                                      <span>{it.name} <span className=\"text-amber-500 font-bold\">x{it.quantity}</span></span>\n                                    </div>\n                                  ))}\n                                </div>\n                              </td>\n\n                              <td className=\"p-4 text-right font-mono font-bold text-amber-500 text-sm\">\n                                ${order.total_amount.toLocaleString(\"es-CL\")}\n                              </td>\n\n                              <td className=\"p-4 text-center font-mono text-neutral-500 text-[10px]\">\n                                {new Date(order.created_at).toLocaleString(\"es-CL\", { dateStyle: \"short\", timeStyle: \"short\" })}\n                              </td>\n\n                              <td className=\"p-4 text-center\">\n                                {isEditing ? (\n                                  <select\n                                    value={editStatus}\n                                    onChange={e => setEditStatus(e.target.value as any)}\n                                    className=\"bg-neutral-950 border border-neutral-800 rounded px-2 py-1 text-xs text-white\"\n                                  >\n                                    <option value=\"Pendiente\">Pendiente</option>\n                                    <option value=\"Preparando\">Preparando</option>\n                                    <option value=\"Enviado\">Enviado</option>\n                                    <option value=\"Entregado\">Entregado</option>\n                                    <option value=\"Cancelado\">Cancelado</option>\n                                  </select>\n                                ) : (\n                                  <span className={`px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${\n                                    order.status === \"Pendiente\" ? \"bg-zinc-800 text-zinc-300 border border-zinc-700\" :\n                                    order.status === \"Preparando\" ? \"bg-amber-950/40 text-amber-400 border border-amber-900/40\" :\n                                    order.status === \"Enviado\" ? \"bg-blue-950/40 text-blue-400 border border-blue-900/40\" :\n                                    order.status === \"Entregado\" ? \"bg-green-950/40 text-green-400 border border-green-900/40\" :\n                                    \"bg-red-950/40 text-red-400 border border-red-900/40\"\n                                  }`}>\n                                    {order.status}\n                                  </span>\n                                )}\n                              </td>\n\n                              <td className=\"p-4 text-center\">\n                                <div className=\"flex items-center justify-center gap-2\">\n                                  {isEditing ? (\n                                    <>\n                                      <button\n                                        onClick={() => handleSaveEdit(order.id)}\n                                        className=\"bg-green-600 hover:bg-green-500 text-neutral-950 p-1.5 rounded transition\"\n                                        title=\"Guardar Modificaciones\"\n                                      >\n                                        <Save className=\"w-3.5 h-3.5\" />\n                                      </button>\n                                      <button\n                                        onClick={() => setEditingOrderId(null)}\n                                        className=\"bg-neutral-800 hover:bg-neutral-700 text-neutral-300 p-1.5 rounded transition\"\n                                        title=\"Cancelar\"\n                                      >\n                                        <XCircle className=\"w-3.5 h-3.5\" />\n                                      </button>\n                                    </>\n                                  ) : (\n                                    <>\n                                      <button\n                                        onClick={() => handleStartEdit(order)}\n                                        className=\"bg-neutral-905 hover:bg-neutral-800 text-amber-500 border border-neutral-800 hover:border-amber-900/40 p-1.5 rounded transition\"\n                                        title=\"Editar Registro\"\n                                        id={`btn-edit-${order.id}`}\n                                      >\n                                        <Edit className=\"w-3.5 h-3.5\" />\n                                      </button>\n                                      <button\n                                        onClick={() => handleDelete(order.id)}\n                                        className=\"bg-neutral-905 hover:bg-red-950/40 text-red-500 border border-neutral-800 hover:border-red-900/40 p-1.5 rounded transition\"\n                                        title=\"Eliminar Pedido\"\n                                        id={`btn-delete-${order.id}`}\n                                      >\n                                        <Trash2 className=\"w-3.5 h-3.5\" />\n                                      </button>\n                                    </>\n                                  )}\n                                </div>\n                              </td>\n                            </tr>\n                          );\n                        })}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </div>\n\n            </div>\n          )}\n\n          {/* MONTHLY REPORT PANE */}\n          {activePane === \"reports\" && (\n            <div className=\"space-y-6\">\n              <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-6\">\n                \n                <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-b border-neutral-900 pb-4 mb-6\">\n                  <div>\n                    <h3 className=\"font-bold text-sm text-neutral-100 flex items-center gap-1.5\">\n                      <BarChart2 className=\"w-5 h-5 text-amber-500\" /> Cierre Mensual Autom\303\241tico de Ventas\n                    </h3>\n                    <p className=\"text-[10px] text-neutral-500 mt-0.5\">M\303\251tricas financieras consolidadas y c\303\241lculo proporcional de categor\303\255as de consumo.</p>\n                  </div>\n                  \n                  <button\n                    onClick={() => {\n                      // Generate and download a CSV representation of the report\n                      const headers = [\"Mes\", \"Ingresos Totales\", \"Pedidos Despachados\", \"Ticket Promedio\", \"Monto Carnes \360\237\245\251\", \"Monto Abarrotes \360\237\252\265\\n\"];\n                      const rows = monthlyReport.map(r => [\n                        r.month,\n                        r.total.toString(),\n                        r.orders_count.toString(),\n                        r.average_ticket.toString(),\n                        r.shares.carne.toString(),\n                        r.shares.abarrotes.toString()\n                      ].join(\",\"));\n                      \n                      const csvContent = \"data:text/csv;charset=utf-8,\" + headers.join(\",\") + rows.join(\"\\n\");\n                      const encodedUri = encodeURI(csvContent);\n                      const link = document.createElement(\"a\");\n                      link.setAttribute(\"href\", encodedUri);\n                      link.setAttribute(\"download\", \"Reporte_Mensual_Ventas_EntreParrilleros.csv\");\n                      document.body.appendChild(link);\n                      link.click();\n                      document.body.removeChild(link);\n                    }}\n                    className=\"bg-amber-600 hover:bg-amber-500 text-neutral-950 px-3 py-1.5 rounded-lg text-xs font-bold font-mono flex items-center gap-1.5 active:scale-95 transition\"\n                  >\n                    <Download className=\"w-3.5 h-3.5\" /> Exportar Reporte (.CSV)\n                  </button>\n                </div>\n\n                {loadingReport ? (\n                  <div className=\"py-12 text-center text-xs text-neutral-500 font-mono\">\n                    <RefreshCw className=\"w-5 h-5 animate-spin mx-auto text-amber-500 mb-2\" />\n                    Consolidando extractos fiscales...\n                  </div>\n                ) : monthlyReport.length === 0 ? (\n                  <div className=\"py-12 text-center text-xs text-neutral-500\">\n                    Sube pedidos en la landing page para ver aparecer informes de cierre autom\303\241ticos.\n                  </div>\n                ) : (\n                  <div className=\"space-y-8\">\n                    \n                    {/* Month list blocks */}\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                      {monthlyReport.map((m, idx) => {\n                        const totalShares = m.shares.carne + m.shares.abarrotes;\n                        const carnePct = totalShares > 0 ? Math.round((m.shares.carne / totalShares) * 100) : 0;\n                        const abarrotesPct = totalShares > 0 ? Math.round((m.shares.abarrotes / totalShares) * 100) : 0;\n\n                        return (\n                          <div key={idx} className=\"bg-neutral-950 border border-neutral-900 rounded-xl p-5 space-y-4 relative\">\n                            <span className=\"absolute top-4 right-4 text-[9px] bg-amber-950 text-amber-400 border border-amber-900/40 font-bold px-2 py-0.5 rounded font-mono uppercase tracking-wide\">\n                              Autom\303\241tico\n                            </span>\n\n                            <h4 className=\"font-extrabold text-neutral-200 text-sm capitalize\">{m.month}</h4>\n                            \n                            <div className=\"grid grid-cols-3 gap-2 font-mono text-[11px] leading-relaxed\">\n                              <div>\n                                <span className=\"text-neutral-500 block\">Venta Bruta:</span>\n                                <strong className=\"text-amber-500 text-sm font-black\">${m.total.toLocaleString(\"es-CL\")}</strong>\n                              </div>\n                              <div>\n                                <span className=\"text-neutral-500 block\">N\302\260 Pedidos:</span>\n                                <strong className=\"text-neutral-300 font-bold\">{m.orders_count} \303\263rdenes</strong>\n                              </div>\n                              <div>\n                                <span className=\"text-neutral-500 block\">Ticket Medio:</span>\n                                <strong className=\"text-neutral-300 font-bold\">${m.average_ticket.toLocaleString(\"es-CL\")}</strong>\n                              </div>\n                            </div>\n\n                            {/* visual progress bar */}\n                            <div className=\"space-y-1.5 pt-2\">\n                              <span className=\"text-[10px] uppercase font-mono text-neutral-500 block\">Distribuci\303\263n de Venta (Market Share)</span>\n                              <div className=\"h-2.5 rounded-full bg-neutral-900 flex overflow-hidden\">\n                                <div \n                                  style={{ width: `${carnePct}%` }} \n                                  className=\"h-full bg-gradient-to-r from-red-700 to-red-600\"\n                                  title={`Carnes Premium: ${carnePct}%`}\n                                />\n                                <div \n                                  style={{ width: `${abarrotesPct}%` }} \n                                  className=\"h-full bg-gradient-to-r from-amber-600 to-yellow-500\"\n                                  title={`Abarrotes: ${abarrotesPct}%`}\n                                />\n                              </div>\n\n                              <div className=\"flex items-center justify-between text-[10px] font-mono text-neutral-400\">\n                                <div className=\"flex items-center gap-1.5\">\n                                  <span className=\"inline-block w-2.5 h-2.5 bg-red-600 rounded-sm\" />\n                                  <span>Meats (\360\237\245\251 {carnePct}%)</span>\n                                </div>\n                                <div className=\"flex items-center gap-1.5\">\n                                  <span className=\"inline-block w-2.5 h-2.5 bg-amber-500 rounded-sm\" />\n                                  <span>Groceries (\360\237\252\265 {abarrotesPct}%)</span>\n                                </div>\n                              </div>\n                            </div>\n                          </div>\n                        );\n                      })}\n                    </div>\n\n                    {/* Report statement note */}\n                    <div className=\"p-4 bg-neutral-950 border border-neutral-900 text-neutral-400 leading-relaxed text-xs flex gap-3\">\n                      <span className=\"text-base select-none\">\360\237\223\212</span>\n                      <p>\n                        <strong>Compilaci\303\263n de Datos en Tiempo Real:</strong> Cada vez que se agrega un pedido o se modifica su valor relacional, esta contabilidad se recalcula autom\303\241ticamente en microsegundos y consolida el promedio del ticket por mes.\n                      </p>\n                    </div>\n\n                  </div>\n                )}\n\n              </div>\n            </div>\n          )}\n\n          {/* GOOGLE SHEETS SETTINGS PANE */}\n          {activePane === \"sheets\" && (\n            <div className=\"space-y-6\">\n              \n              <div className=\"grid grid-cols-1 md:grid-cols-12 gap-8\">\n                \n                {/* Configuration form (Left) */}\n                <div className=\"md:col-span-6 bg-neutral-900/30 border border-neutral-900 rounded-xl p-6\">\n                  \n                  <div className=\"flex items-center gap-2 border-b border-neutral-900 pb-4 mb-4\">\n                    <FileSpreadsheet className=\"w-5 h-5 text-amber-500\" />\n                    <div>\n                      <h3 className=\"font-bold text-sm text-neutral-100\">Enlace Planilla Google Sheets</h3>\n                      <p className=\"text-[10px] text-neutral-500 mt-0.5\">Instancia la API del Cloud de Google Spreadsheet para depositar filas.</p>\n                    </div>\n                  </div>\n\n                  {syncStatusMsg && (\n                    <div className=\"p-3 mb-4 bg-zinc-950/80 border border-amber-900/30 rounded-lg text-amber-500 font-mono text-xs leading-relaxed\">\n                      {syncStatusMsg}\n                    </div>\n                  )}\n\n                  <form onSubmit={handleUpdateSheetId} className=\"space-y-4\">\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono text-neutral-400 mb-1\">ID de tu Planilla (Google Spreadsheet ID)</label>\n                      <input\n                        type=\"text\"\n                        required\n                        value={sheetsConfig.sheetId}\n                        onChange={e => setSheetsConfig(prev => ({ ...prev, sheetId: e.target.value }))}\n                        placeholder=\"Ej. 1Y8gYp99G152P7Fv6ZzY...\"\n                        className=\"w-full bg-neutral-950 border border-neutral-800 rounded-lg px-3 py-2 text-xs focus:border-amber-600 outline-none text-zinc-300 font-mono\"\n                      />\n                      <span className=\"text-[10px] text-neutral-500 mt-1.5 block leading-relaxed\">\n                        Extra\303\255do de la URL: `https://docs.google.com/spreadsheets/d/<strong>[SPREADSHEET_ID]</strong>/edit`\n                      </span>\n                    </div>\n\n                    <div className=\"flex items-center gap-3\">\n                      <button\n                        type=\"submit\"\n                        className=\"bg-amber-600 hover:bg-amber-500 text-neutral-950 text-xs font-bold px-4 py-2 rounded-lg transition font-mono\"\n                      >\n                        Actualizar Celda ID\n                      </button>\n                      \n                      <button\n                        type=\"button\"\n                        onClick={triggerManualGroupSync}\n                        disabled={syncingAll}\n                        className=\"bg-neutral-800 hover:bg-neutral-750 text-neutral-300 border border-neutral-700 px-4 py-2 rounded-lg text-xs font-bold transition font-mono flex items-center gap-2\"\n                      >\n                        {syncingAll ? \"Sincronizando...\" : `Exportar Todo (${orders.length} pedidos)`}\n                      </button>\n                    </div>\n                  </form>\n                </div>\n\n                {/* Documentation / Procedure (Right) */}\n                <div className=\"md:col-span-6 bg-neutral-900/10 border border-neutral-900 rounded-xl p-6 text-xs text-neutral-400 space-y-4\">\n                  <h4 className=\"font-bold text-neutral-200 flex items-center gap-1.5 text-sm\">\n                    <ShieldCheck className=\"w-5 h-5 text-amber-500\" /> Sincronizaci\303\263n Segura\n                  </h4>\n                  \n                  <p className=\"leading-relaxed\">\n                    Nuestro sistema utiliza una conexi\303\263n integrada directa con la <strong>Google Sheets REST API v4</strong>. Cada vez que recibimos un pedido en la landing page principal:\n                  </p>\n\n                  <ul className=\"space-y-2 list-disc pl-4 leading-relaxed\">\n                    <li>Se inyectan el nombre, correo, WhatsApp, sucursal (\"Osorno Centro\" u otra) e importe consolidado del asado.</li>\n                    <li>No dependemos de plugins lentos, la llamada API se ejecuta en segundo plano.</li>\n                    <li>Si la credencial de Google Cloud no est\303\241 cargada, operamos un simulador que muestra logs exactos para evitar fallos de renderizado.</li>\n                  </ul>\n                </div>\n\n              </div>\n\n            </div>\n          )}\n\n        </div>\n\n      </div>\n    </div>\n  );\n}\n"
