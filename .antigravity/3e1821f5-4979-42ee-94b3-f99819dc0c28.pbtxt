          text: "              "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <p className=\"text-neutral-500 text-xs leading-relaxed mb-6\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <strong>\302\277Quieres ver la velocidad en segundos?</strong> Simula la inserci\303\263n de una transacci\303\263n hist\303\263rica de compras directamente en Laragon. Los clasificadores paralelos se volver\303\241n a entrenar y el gr\303\241fico Plotly de la izquierda se actualizar\303\241 instant\303\241neamente."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              {simSuccess && ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <div className=\"p-3 mb-4 bg-green-950/40 border border-green-800/40 rounded-lg text-green-400 text-xs font-mono\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  \342\234\224 \302\241Registro guardado! M\303\251tricas actualizadas en 0.82 segundos."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
