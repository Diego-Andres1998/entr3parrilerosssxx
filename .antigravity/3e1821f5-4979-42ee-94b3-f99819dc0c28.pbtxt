    replacement_infos {
      original_chunk {
        target_content: "                {/* Pandas Filtering and Aggregation results */}\n                {activeTab === \"pandas\" && (\n                  <div className=\"space-y-6\">\n                    <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-6\">\n                      <div className=\"flex items-center gap-2 border-b border-neutral-900 pb-4 mb-4\">\n                        <Layers className=\"w-5 h-5 text-amber-500\" />\n                        <div>\n                          <h3 className=\"font-bold text-sm text-neutral-100\">Filtrado Avanzado Segmento \"Osorno Centro\"</h3>\n                          <p className=\"text-[10px] text-neutral-500 mt-0.5\">Aislamiento de la sucursal Osorno y agrupaci\303\263n por el estado de Fuga de Clientes.</p>\n                        </div>\n                      </div>\n\n                      {/* Arithmetic means tables */}\n                      <div className=\"overflow-x-auto\">\n                        <table className=\"w-full text-xs text-left text-neutral-300 border-collapse\">\n                          <thead>\n                            <tr className=\"bg-neutral-900/60 text-neutral-400 font-mono text-[10px] uppercase border-b border-neutral-800\">\n                              <th className=\"p-3\">Estado de Fuga</th>\n                              <th className=\"p-3 text-center\">N\302\260 Registros Relacionales</th>\n                              <th className=\"p-3 text-right\">Media Gasto Mensual</th>\n                              <th className=\"p-3 text-right\">Media Visitas Mensuales</th>\n                              <th className=\"p-3 text-center\">An\303\241lisis de Riesgo</th>\n                            </tr>\n                          </thead>\n                          <tbody>\n                            {data?.aggregation.map(row => (\n                              <tr key={row.is_fuga} className=\"border-b border-neutral-900 hover:bg-neutral-900/20\">\n                                <td className=\"p-3 font-semibold\">\n                                  {row.is_fuga === 1 ? (\n                                    <span className=\"text-red-400 bg-red-950/40 border border-red-900/30 px-2 py-0.5 rounded font-mono uppercase text-[10px]\">\n                                      Fuga (Churn)\n                                    </span>\n                                  ) : (\n                                    <span className=\"text-green-400 bg-green-950/40 border border-green-900/30 px-2 py-0.5 rounded font-mono uppercase text-[10px]\">\n                                      Activo (Retenci\303\263n)\n                                    </span>\n                                  )}\n                                </td>\n                                <td className=\"p-3 text-center font-mono\">{row.count} clientes</td>\n                                <td className=\"p-3 text-right font-mono text-amber-500 font-bold\">\n                                  ${row.avg_spending.toLocaleString(\"es-CL\")} CLP\n                                </td>\n                                <td className=\"p-3 text-right font-mono text-neutral-400\">\n                                  {row.avg_visits.toFixed(2)} visitas/mes\n                                </td>\n                                <td className=\"p-3 text-center\">\n                                  {row.is_fuga === 1 ? (\n                                    <span className=\"text-yellow-600 font-bold\">Bajo Consumo / Inactivo</span>\n                                  ) : (\n                                    <span className=\"text-green-600 font-bold\">Fiel / Invitado VIP</span>\n                                  )}\n                                </td>\n                              </tr>\n                            ))}\n                          </tbody>\n                        </table>\n                      </div>\n\n                      <div className=\"bg-neutral-950 border border-neutral-900 mt-6 rounded-lg p-4 font-mono text-[11px] leading-relaxed text-neutral-400\">\n                        <span className=\"text-amber-500 font-bold\"># Consulta Ejecutada Equivalente en Pandas:</span>\n                        <pre className=\"mt-2 text-zinc-300 overflow-x-auto select-all bg-neutral-950 p-2 rounded\">\n{`osorno_df = df[df[\'branch\'] == \'Osorno Centro\']\nreporte_agrupado = osorno_df.groupby(\'is_fuga\')[[\'monthly_spending\', \'monthly_visits\']].mean()\nprint(reporte_agrupado)`}\n                        </pre>\n                      </div>\n                    </div>\n                  </div>\n                )}"
        replacement_content: "                {/* Pandas Filtering and Aggregation results */}\n                {activeTab === \"pandas\" && (\n                  <div className=\"space-y-6\">\n                    <div className=\"bg-[#161616] border border-white/10 rounded-none p-6\">\n                      <div className=\"flex items-center gap-2 border-b border-white/5 pb-4 mb-4\">\n                        <Layers className=\"w-5 h-5 text-[#b91c1c]\" />\n                        <div>\n                          <h3 className=\"font-serif italic text-white text-base\">Filtrado Avanzado Segmento \"Osorno Centro\"</h3>\n                          <p className=\"text-[10px] uppercase tracking-wider text-zinc-500 mt-1 font-semibold\">Aislamiento de la sucursal Osorno y agrupaci\303\263n por el estado de Fuga de Clientes.</p>\n                        </div>\n                      </div>\n\n                      {/* Arithmetic means tables */}\n                      <div className=\"overflow-x-auto\">\n                        <table className=\"w-full text-xs text-left text-zinc-300 border-collapse\">\n                          <thead>\n                            <tr className=\"bg-[#121212] text-zinc-500 font-mono text-[9px] uppercase tracking-widest border-b border-white/10\">\n                              <th className=\"p-3\">Estado de Fuga</th>\n                              <th className=\"p-3 text-center\">N\302\260 Registros Relacionales</th>\n                              <th className=\"p-3 text-right\">Media Gasto Mensual</th>\n                              <th className=\"p-3 text-right\">Media Visitas Mensuales</th>\n                              <th className=\"p-3 text-center\">An\303\241lisis de Riesgo</th>\n                            </tr>\n                          </thead>\n                          <tbody>\n                            {data?.aggregation.map(row => (\n                              <tr key={row.is_fuga} className=\"border-b border-white/5 hover:bg-white/[0.01]\">\n                                <td className=\"p-3\">\n                                  {row.is_fuga === 1 ? (\n                                    <span className=\"text-red-400 bg-red-950/20 border border-red-900/30 px-2.5 py-0.5 rounded-none font-mono uppercase text-[9px] tracking-wider font-semibold\">\n                                      Fuga (Churn)\n                                    </span>\n                                  ) : (\n                                    <span className=\"text-green-400 bg-green-950/20 border border-green-900/30 px-2.5 py-0.5 rounded-none font-mono uppercase text-[9px] tracking-wider font-semibold\">\n                                      Activo (Retenci\303\263n)\n                                    </span>\n                                  )}\n                                </td>\n                                <td className=\"p-3 text-center font-mono text-zinc-300\">{row.count} clientes</td>\n                                <td className=\"p-3 text-right font-mono text-[#b91c1c] font-bold\">\n                                  ${row.avg_spending.toLocaleString(\"es-CL\")} CLP\n                                </td>\n                                <td className=\"p-3 text-right font-mono text-zinc-400\">\n                                  {row.avg_visits.toFixed(2)} visitas/mes\n                                </td>\n                                <td className=\"p-3 text-center font-mono text-[10px] uppercase tracking-wider font-semibold\">\n                                  {row.is_fuga === 1 ? (\n                                    <span className=\"text-red-500\">Inactivo</span>\n                                  ) : (\n                                    <span className=\"text-zinc-400 font-bold\">Invitado VIP</span>\n                                  )}\n                                </td>\n                              </tr>\n                            ))}\n                          </tbody>\n                        </table>\n                      </div>\n\n                      <div className=\"bg-[#121212] border border-white/10 mt-6 rounded-none p-4 font-mono text-[11px] leading-relaxed text-zinc-400\">\n                        <span className=\"text-[#b91c1c] font-bold\"># Consulta Ejecutada Equivalente en Pandas:</span>\n                        <pre className=\"mt-2 text-zinc-300 overflow-x-auto select-all bg-[#121212] p-2 rounded-none\">\n{`osorno_df = df[df[\'branch\'] == \'Osorno Centro\']\nreporte_agrupado = osorno_df.groupby(\'is_fuga\')[[\'monthly_spending\', \'monthly_visits\']].mean()\nprint(reporte_agrupado)`}\n                        </pre>\n                      </div>\n                    </div>\n                  </div>\n                )}"
      }
      num_matches: 1
    }
  }
}
