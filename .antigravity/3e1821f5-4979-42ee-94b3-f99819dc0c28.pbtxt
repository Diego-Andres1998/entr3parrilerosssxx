    replacement_infos {
      original_chunk {
        target_content: "              <button\n                onClick={() => setActiveTab(\"code\")}\n                className={`px-4 py-2 rounded-none text-[10px] uppercase font-mono tracking-widest font-semibold transition-all ${\n                  activeTab === \"code\" ? \"bg-[#b91c1c] text-white font-bold\" : \"text-zinc-500 hover:text-white\"\n                }`}\n                id=\"btn-tab-code\"\n              >\n                Integraci\303\263n Python\n              </button>\n            </div>ton>\n            </div>\n\n            {loading ? (\n              <div className=\"flex flex-col items-center justify-center p-24 text-neutral-500\">\n                <RefreshCw className=\"w-8 h-8 animate-spin text-amber-500 mb-2\" />\n                <span className=\"text-xs font-mono\">Ejecutando ajuste de modelos relacionales...</span>\n              </div>\n            ) : errorMessage ? (\n              <div className=\"p-8 border border-red-900/40 bg-red-950/20 rounded-xl text-red-400 text-xs\">\n                {errorMessage}\n              </div>\n            ) : (\n              <div>\n                {/* Visuals Subtab */}\n                {activeTab === \"visuals\" && (\n                  <div className=\"space-y-6\">\n                    {/* Plotly scatter plot graphic container */}\n                    <div className=\"bg-neutral-900/30 border border-neutral-900 rounded-xl p-5\">\n                      <div className=\"flex items-center justify-between mb-4 border-b border-neutral-900 pb-3\">\n                        <div>\n                          <h3 className=\"font-bold text-neutral-200 text-sm\">Distribuci\303\263n de Gastos vs. Visitas Mensuales</h3>\n                          <p className=\"text-[10px] text-neutral-500 mt-0.5\">Vector din\303\241mico generado por Plotly Express simulado</p>\n                        </div>\n                        <span className=\"px-2 py-0.5 rounded text-[9px] bg-amber-950 text-amber-400 font-mono border border-amber-900/40\">Vector SVG Din\303\241mico</span>\n                      </div>\n                      \n                      {/* Live Rendered Chart SVG from server! */}\n                      {data?.chartHtml ? (\n                        <div \n                          className=\"w-full\"\n                          dangerouslySetInnerHTML={{ __html: data.chartHtml }} \n                        />\n                      ) : (\n                        <div className=\"py-20 text-center text-neutral-600 text-xs\">Fallo en generaci\303\263n de vectores. (Comprueba la base de datos)</div>\n                      )}\n                    </div>\n\n                    {/* Classifier Scores Cards */}\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                      \n                      <div className=\"bg-neutral-900/25 border border-neutral-900 rounded-xl p-5 flex items-start gap-4\">\n                        <span className=\"p-3 rounded-lg bg-green-950/30 border border-green-900/40 text-green-400 text-xl font-bold font-mono\">\n                          \360\237\214\262\n                        </span>\n                        <div>\n                          <h4 className=\"text-xs text-neutral-400 uppercase tracking-wider font-mono\">Precisi\303\263n de \303\201rbol de Decisi\303\263n</h4>\n                          <h3 className=\"text-2xl font-black text-white mt-1 font-mono\">{data?.metrics.dtAccuracy}%</h3>\n                          <p className=\"text-[10px] text-neutral-500 mt-1\">L\303\255mite de profundidad m\303\241xima configurado en = 4</p>\n                        </div>\n                      </div>\n\n                      <div className=\"bg-neutral-900/25 border border-neutral-900 rounded-xl p-5 flex items-start gap-4\">\n                        <span className=\"p-3 rounded-lg bg-blue-950/30 border border-blue-900/40 text-blue-400 text-xl font-bold font-mono\">\n                          \342\232\241\