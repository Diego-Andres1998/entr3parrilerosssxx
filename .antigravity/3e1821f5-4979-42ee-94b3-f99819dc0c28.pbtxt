          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                          <p className=\"text-[10px] uppercase tracking-wider text-zinc-500 mt-1 font-semibold\">Usa este script en Laragon para lograr sincronizaci\303\263n relacional, entrenamiento y refresco en segundos.</p>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
