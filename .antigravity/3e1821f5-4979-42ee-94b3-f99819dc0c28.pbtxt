        lines {
          text: "    title=\"An\303\241lisis de Fuga de Clientes - Entre Parrilleros\","
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    labels={\'monthly_spending\':\'Gastos Mensuales ($)\', \'monthly_visits\':\'Visitas al Mes\'},"
