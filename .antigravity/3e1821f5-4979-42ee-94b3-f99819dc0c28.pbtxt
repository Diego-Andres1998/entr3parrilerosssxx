lex flex-col md:flex-row items-start gap-4\">\n          <Sparkles className=\"w-6 h-6 text-[#b91c1c] shrink-0 mt-0.5\" />\n          <div>\n            <h3 className=\"font-serif italic text-white text-base\">\302\277C\303\263mo se actualiza este Dashboard en Tiempo Real al modificar Laragon?</h3>\n            <p className=\"text-zinc-400 text-xs mt-1.5 leading-relaxed font-semibold\">\n              <strong>El Procedimiento T\303\251cnico:</strong> Cuando el due\303\261o a\303\261ade compras directamente en HeidiSQL/Laragon, no se requiere reescribir ni recompilar la p\303\241gina web. \n              El frontend se comunica con un backend din\303\241mico en Express que realiza la consulta SQL unificada por <code>JOIN</code> en segundos. Al llamar la API <code>/api/ml-analysis</code>, \n              pandas-like filters operan en tiempo real, re-entrenando instant\303\241neamente los algoritmos locales de <strong className=\"text-white\">\303\201rbol de Decisi\303\263n</strong> y <strong className=\"text-white\">KNN</strong> con los datos frescos y actualizando las proyecciones y el gr\303\241fico de vector interactivo en milisegundos.\n            </p>\n          </div>\n        </div>\n\n        {/* Dashboard Grid split */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          \n          {/* Main Visualizers Panel (Left) */}\n          <div className=\"lg:col-span-8 space-y-6\">\n            \n            {/* Nav Filters inner tabs */}\n            <div className=\"flex items-center gap-2 border-b border-white/10 pb-3\">\n              <button\n                onClick={() => setActiveTab(\"visuals\")}\n                className={`px-4 py-2 rounded-none text-[10px] uppercase font-mono tracking-widest font-semibold transition-all ${\n                  activeTab === \"visuals\" ? \"bg-[#b91c1c] text-white font-bold\" : \"text-zinc-500 hover:text-white\"\n                }`}\n                id=\"btn-tab-visuals\"\n              >\n        