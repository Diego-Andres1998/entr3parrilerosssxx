          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                ) : monthlyReport.length === 0 ? ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  <div className=\"py-12 text-center text-xs text-neutral-500\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
