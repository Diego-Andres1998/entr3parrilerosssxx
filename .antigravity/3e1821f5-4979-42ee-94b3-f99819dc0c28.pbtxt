        }
        lines {
          text: "    color_discrete_map={0:\'green\', 1:\'red\'}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: ")"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "plot_html_block = fig.to_html(full_html=False, include_plotlyjs=\'cdn\')"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
