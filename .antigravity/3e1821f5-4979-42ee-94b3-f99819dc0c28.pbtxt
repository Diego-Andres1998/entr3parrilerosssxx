        }
        lines {
          text: "                      <BarChart2 className=\"w-5 h-5 text-[#b91c1c]\" /> Cierre Mensual Autom\303\241tico de Ventas"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    </h3>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <p className=\"text-[10px] uppercase tracking-wider text-zinc-500 mt-1 font-semibold\">M\303\251tricas financieras consolidadas y c\303\241lculo proporcional de categor\303\255as de consumo.</p>"
