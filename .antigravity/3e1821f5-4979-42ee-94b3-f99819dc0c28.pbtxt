        }
        lines {
          text: "        is_fuga: key,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        count: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        avg_spending: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        avg_visits: 0"
