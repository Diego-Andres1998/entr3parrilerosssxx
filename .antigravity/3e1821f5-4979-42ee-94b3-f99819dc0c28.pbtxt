          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              </motion.div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            )}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "          </AnimatePresence>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "        </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "      </section>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    </div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
      }
    }
    instruction: "Re-style LandingPage.tsx to Editorial Aesthetic theme with sharp layouts, uppercase serif taggings, and deep red highlights"
    replacement_infos {
      original_chunk {
        target_content: "  return (\n    <div className=\"min-h-screen bg-neutral-950 text-neutral-100\">\n      {/* Hero Banner Section */}\n      <section className=\"relative overflow-hidden border-b border-red-950/40 bg-gradient-to-b from-red-950/20 via-neutral-950 to-neutral-950 px-6 py-16 text-center md:py-24\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-amber-950/10 via-transparent to-transparent pointer-events-none\" />\n        \n        <div className=\"relative mx-auto max-w-3xl\">\n          <div className=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-950/40 border border-red-900/50 text-amber-500 font-mono text-xs uppercase mb-6 tracking-widest animate-pulse\">\n            <Flame className=\"w-4 h-4 text-red-500 fill-red-500\" /> Selecci\303\263n Boutique Chile\n          </div>\n          \n          <h1 className=\"font-sans text-4xl font-extrabold tracking-tight md:text-6xl text-neutral-50\">\n            Entre <span className=\"text-amber-500 bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent\">Parrilleros</span>\n          </h1>\n          \n          <p className=\"mt-4 text-lg text-neutral-400 font-sans max-w-2xl mx-auto\">\n            La pyme boutique favorita del sur de Chile. Llevamos las mejores carnes premium Angus, abarrotes artesanales y servicio parrillero directo a tu mesa en Osorno y alrededores.\n          </p>\n\n          <div className=\"flex flex-wrap justify-center gap-6 mt-8 text-sm text-neutral-500\">\n            <div className=\"flex items-center gap-2 bg-neutral-900/60 px-4 py-2 rounded-lg border border-neutral-900\">\n              <MapPin className=\"w-4 h-4 text-amber-500\" /> Sucursal: Osorno Centro\n            </div>\n            <div className=\"flex items-center gap-2 bg-neutral-900/60 px-4 py-2 rounded-lg border border-neutral-900\">\n              <Truck className=\"w-4 h-4 text-amber-500\" /> Despacho a Domicilio R\303\241pido\n            </div>\n            <div className=\"flex items-center gap-2 bg-neutral-900/60 px-4 py-2 rounded-lg border border-neutral-900\">\n              <Award className=\"w-4 h-4 text-amber-500\" /> Calidad de Exportaci\303\263n\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Main Order builder */}\n      <section className=\"mx-auto max-w-7xl px-4 py-12 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12\">\n        \n        {/* Products Column */}\n        <div className=\"lg:col-span-7\">\n          <div className=\"flex items-center justify-between border-b border-neutral-900 pb-5 mb-8\">\n            <div>\n              <h2 className=\"text-2xl font-bold tracking-tight text-neutral-100\">Haz tu Pedido</h2>\n              <p className=\"text-sm text-neutral-500 mt-1\">Arma tu asado perfecto agregando carnes maduradas y accesorios.</p>\n            </div>\n\n            {/* Category selection Tabs */}\n            <div className=\"flex items-center gap-1 bg-neutral-900 p-1 rounded-lg border border-neutral-800\">\n              {([\"todos\", \"carne\", \"abarrotes\"] as const).map(cat => (\n                <button\n                  key={cat}\n                  onClick={() => setSelectedCategory(cat)}\n                  className={`px-3 py-1.5 rounded-md text-xs font-semibold capitalize transition-all ${\n                    selectedCategory === cat \n                      ? \"bg-amber-600 text-neutral-950 font-bold\" \n                      : \"text-neutral-400 hover:text-neutral-200\"\n                  }`}\n                  id={`cat-filter-${cat}`}\n                >\n                  {cat === \"todos\" ? \"Todo\" : cat === \"carne\" ? \"Carnes \360\237\245\251\" : \"Abarrotes \360\237\252\265\"}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Catalog grid */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n            {filteredProducts.map(product => {\n              const q = cart[product.id] || 0;\n              return (\n                <div \n                  key={product.id} \n                  id={`product-card-${product.id}`}\n                  className=\"group relative flex flex-col justify-between bg-neutral-900/40 hover:bg-neutral-900/60 border border-neutral-900 hover:border-amber-950/40 rounded-xl p-5 transition-all duration-300\"\n                >\n                  {product.badge && (\n                    <span className=\"absolute top-4 right-4 bg-amber-950/80 text-amber-400 text-[10px] font-bold px-2 py-0.5 rounded border border-amber-900/50 uppercase tracking-wide font-mono\">\n                      {product.badge}\n                    </span>\n                  )}\n\n                  <div>\n                    <span className=\"text-4xl block mb-4 filter group-hover:scale-110 transition-transform duration-300 select-none\">\n                      {product.image}\n                    </span>\n                    \n                    <h3 className=\"font-bold text-neutral-100 group-hover:text-amber-500 transition-colors\">\n                      {product.name}\n                    </h3>\n                    \n                    <p className=\"text-xs text-neutral-500 mt-2 line-clamp-3 leading-relaxed\">\n                      {product.description}\n                    </p>\n                  </div>\n\n                  <div className=\"flex items-center justify-between mt-6 pt-4 border-t border-neutral-900/60\">\n                    <span className=\"font-mono text-lg font-bold text-amber-500\">\n                      ${product.price.toLocaleString(\"es-CL\")}\n                    </span>\n\n                    {/* Quantity selectors */}\n                    {q > 0 ? (\n                      <div className=\"flex items-center gap-3 bg-neutral-900 border border-neutral-800 rounded-lg p-1\">\n                        <button \n                          onClick={() => updateQuantity(product.id, -1)}\n                          className=\"w-7 h-7 flex items-center justify-center rounded bg-neutral-800 text-neutral-300 hover:bg-red-950/40 hover:text-red-400 transition\"\n                        >\n                          -\n                        </button>\n                        <span className=\"font-mono text-sm font-bold w-4 text-center\">{q}</span>\n                        <button \n                          onClick={() => updateQuantity(product.id, 1)}\n                          className=\"w-7 h-7 flex items-center justify-center rounded bg-neutral-800 text-neutral-300 hover:bg-green-950/40 hover:text-green-400 transition\"\n                        >\n                          +\n                        </button>\n                      </div>\n                    ) : (\n                      <button\n                        onClick={() => updateQuantity(product.id, 1)}\n                        className=\"bg-neutral-800 hover:bg-amber-600 hover:text-neutral-950 text-neutral-300 font-semibold px-3 py-1.5 rounded-lg text-xs flex items-center gap-2 transition-all duration-300 border border-neutral-700/40 active:scale-95\"\n                        id={`add-to-cart-${product.id}`}\n                      >\n                        <ShoppingCart className=\"w-3.5 h-3.5\" /> Agregar\n                      </button>\n                    )}\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Form and Cart Column */}\n        <div className=\"lg:col-span-5 bg-neutral-900/20 border border-neutral-900 rounded-2xl p-6 lg:p-8 h-fit relative\">\n          \n          <div className=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none select-none\">\n            <Flame className=\"w-48 h-48 text-amber-500\" />\n          </div>\n\n          <h3 className=\"text-xl font-bold text-neutral-100 flex items-center gap-2 mb-6 border-b border-neutral-900 pb-4\">\n            <ShoppingCart className=\"w-5 h-5 text-amber-500\" /> Tu Carro Parrillero\n          </h3>\n\n          <AnimatePresence mode=\"wait\">\n            {orderSuccess ? (\n              <motion.div \n                key=\"success-card\"\n                initial={{ opacity: 0, scale: 0.95 }}\n                animate={{ opacity: 1, scale: 1 }}\n                exit={{ opacity: 0 }}\n                className=\"text-center py-6\"\n              >\n                <div className=\"w-16 h-16 bg-green-950 text-green-400 rounded-full flex items-center justify-center mx-auto mb-4 border border-green-800/50\">\n                  <CheckCircle className=\"w-10 h-10\" />\n                </div>\n                \n                <h4 className=\"text-lg font-bold text-green-400\">\302\241Pedido Enviado Exitosamente!</h4>\n                <p className=\"text-xs text-neutral-400 mt-2 max-w-sm mx-auto\">\n                  La orden ha sido ingresada en la base de datos de manera permanente. \n                </p>\n\n                {/* Database logs simulated in realtime */}\n                <div className=\"bg-neutral-950/80 border border-neutral-900 mt-6 rounded-lg p-4 text-left text-xs font-mono\">\n                  <div className=\"flex items-center gap-2 text-amber-500 border-b border-neutral-900 pb-2 mb-2 font-semibold\">\n                    <Flame className=\"w-3.5 h-3.5 animate-pulse\" /> Logs del Servidor en Vivo:\n                  </div>\n                  \n                  <div className=\"space-y-2 text-neutral-400 leading-relaxed text-[11px]\">\n                    <p className=\"text-green-500\">\342\234\224 Guardado definitivo en Laragon MySQL exitoso.</p>\n                    <p className=\"text-neutral-500\">\360\237\224\271 ID Asignado: <span className=\"text-white font-bold\">#{orderSuccess.order?.id}</span></p>\n                    <p className=\"text-neutral-500\">\360\237\224\271 Sucursal de Despacho: {orderSuccess.order?.branch}</p>\n                    \n                    <div className=\"border-t border-neutral-900/60 pt-2 mt-2\">\n                      <p className=\"text-red-400 flex items-center gap-1\">\n                        <Mail className=\"w-3 h-3 text-red-500\" /> Notificaci\303\263n por Correo:\n                      </p>\n                      <p className=\"pl-3 text-neutral-500\">{orderSuccess.notification?.email?.message}</p>\n                    </div>\n\n                    <div className=\"border-t border-neutral-900/60 pt-2\">\n                      <p className=\"text-blue-400 flex items-center gap-1\">\n                        <Send className=\"w-3 h-3 text-blue-500\" /> Sincronizaci\303\263n Google Sheets:\n                      </p>\n                      <p className=\"pl-3 text-neutral-500\">{orderSuccess.notification?.sheets?.message}</p>\n                    </div>\n                  </div>\n                </div>\n\n                <button\n                  onClick={() => setOrderSuccess(null)}\n                  className=\"mt-6 w-full bg-neutral-800 hover:bg-neutral-700 text-neutral-200 font-bold py-2.5 rounded-lg text-xs transition\"\n                >\n                  Armar Otro Pedido\n                </button>\n              </motion.div>\n            ) : getCartCount() === 0 ? (\n              <motion.div \n                key=\"empty-cart\"\n                initial={{ opacity: 0 }}\n                animate={{ opacity: 1 }}\n                className=\"text-center py-16 text-neutral-500\"\n              >\n                <span className=\"text-5xl block mb-3\">\360\237\224\245</span>\n                <p className=\"text-sm font-semibold\">El carro est\303\241 vac\303\255o</p>\n                <p className=\"text-xs text-neutral-600 mt-1 max-w-xs mx-auto\">Selecciona cortes de carne o abarrotes para pre-visualizar el monto total del asado.</p>\n              </motion.div>\n            ) : (\n              <motion.div \n                key=\"active-cart\"\n                initial={{ opacity: 0 }}\n                animate={{ opacity: 1 }}\n                exit={{ opacity: 0 }}\n              >\n                {/* List selected items */}\n                <div className=\"max-h-60 overflow-y-auto mb-6 pr-2 space-y-3 scrollbar-thin\">\n                  {MENU_ITEMS.filter(item => cart[item.id] > 0).map(item => {\n                    const count = cart[item.id];\n                    return (\n                      <div key={item.id} className=\"flex items-center justify-between bg-neutral-900/50 p-3 rounded-lg border border-neutral-900/80\">\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"text-xl\">{item.image}</span>\n                          <div>\n                            <h4 className=\"text-xs font-bold text-neutral-200\">{item.name}</h4>\n                            <p className=\"text-[10px] text-neutral-500 mt-0.5\">\n                              ${item.price.toLocaleString(\"es-CL\")} x {count}\n                            </p>\n                          </div>\n                        </div>\n\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"font-mono text-xs font-bold text-amber-500\">\n                            ${(item.price * count).toLocaleString(\"es-CL\")}\n                          </span>\n                          <button\n                            onClick={() => updateQuantity(item.id, -count)}\n                            className=\"text-neutral-600 hover:text-red-500 p-1 transition\"\n                            title=\"Quitar todo\"\n                          >\n                            <Trash2 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n\n                {/* Subtotal */}\n                <div className=\"border-t border-neutral-900 pt-4 mb-6 space-y-2\">\n                  <div className=\"flex items-center justify-between text-xs text-neutral-500\">\n                    <span>Subtotal de Art\303\255culos</span>\n                    <span className=\"font-mono\">${getCartTotal().toLocaleString(\"es-CL\")}</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs text-neutral-500\">\n                    <span>Despacho</span>\n                    <span className=\"text-green-500 font-semibold font-mono\">GRATIS</span>\n                  </div>\n                  <div className=\"flex items-center justify-between pt-2 border-t border-neutral-900/60\">\n                    <span className=\"font-semibold text-neutral-300\">Total Estimado</span>\n                    <span className=\"font-mono text-xl font-bold text-amber-500\">\n                      ${getCartTotal().toLocaleString(\"es-CL\")}\n                    </span>\n                  </div>\n                </div>\n\n                {/* Buyer Form */}\n                <form onSubmit={handleCheckout} className=\"space-y-4 pt-4 border-t border-neutral-950\">\n                  <h4 className=\"text-xs font-bold text-amber-500 uppercase tracking-widest font-mono\">Tus Datos de Despacho</h4>\n                  \n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Nombre Completo</label>\n                    <input\n                      type=\"text\"\n                      required\n                      value={customerName}\n                      onChange={e => setCustomerName(e.target.value)}\n                      placeholder=\"Ej. Gonzalo Retamal\"\n                      className=\"w-full bg-neutral-950 border border-neutral-800 focus:border-amber-600 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                      id=\"input-customer-name\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Email de Contacto</label>\n                      <input\n                        type=\"email\"\n                        required\n                        value={email}\n                        onChange={e => setEmail(e.target.value)}\n                        placeholder=\"Ej. gonzalo@gmail.com\"\n                        className=\"w-full bg-neutral-950 border border-neutral-800 focus:border-amber-600 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"input-customer-email\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">WhatsApp / Celular</label>\n                      <input\n                        type=\"text\"\n                        required\n                        value={phone}\n                        onChange={e => setPhone(e.target.value)}\n                        placeholder=\"Ej. +56982731192\"\n                        className=\"w-full bg-neutral-950 border border-neutral-800 focus:border-amber-600 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"input-customer-phone\"\n                      />\n                    </div>\n                  </div>\n\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Sucursal Asociada</label>\n                      <select\n                        value={branch}\n                        onChange={e => setBranch(e.target.value)}\n                        className=\"w-full bg-neutral-950 border border-neutral-800 focus:border-amber-600 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"select-customer-branch\"\n                      >\n                        <option value=\"Osorno Centro\">Osorno Centro</option>\n                        <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                        <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                      </select>\n                    </div>\n\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">V\303\255a de Recepci\303\263n</label>\n                      <div className=\"w-full bg-neutral-950/40 border border-neutral-800 font-semibold rounded-lg px-3 py-2 text-xs text-amber-500 flex items-center gap-2\">\n                        <Truck className=\"w-3.5 h-3.5\" /> Despacho a Domicilio\n                      </div>\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono text-neutral-500 mb-1\">Comentarios / Indicaci\303\263n de Corte</label>\n                    <textarea\n                      value={notes}\n                      onChange={e => setNotes(e.target.value)}\n                      placeholder=\"Ej. Prefiero el lomo vetado en un solo trozo / Entregar despu\303\251s de las 18:00 hrs.\"\n                      rows={2}\n                      className=\"w-full bg-neutral-950 border border-neutral-800 focus:border-amber-600 rounded-lg px-3 py-2 text-xs text-neutral-100 outline-none transition resize-none\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    disabled={isSubmitting}\n                    className=\"w-full bg-amber-600 hover:bg-amber-500 disabled:bg-neutral-800 text-neutral-950 font-bold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition duration-300 transform active:scale-95 text-xs select-none\"\n                    id=\"submit-order-checkout\"\n                  >\n                    {isSubmitting ? (\n                      <>Procesando Solicitud...</>\n                    ) : (\n                      <>\n                        <Flame className=\"w-4 h-4 fill-neutral-950\" /> Confirmar Pedido Parrillero (${getCartTotal().toLocaleString(\"es-CL\")})\n                      </>\n                    )}\n                  </button>\n\n                  <div className=\"flex items-center justify-center gap-2 text-[10px] text-neutral-500 pb-2\">\n                    <ShieldCheck className=\"w-3.5 h-3.5 text-amber-600\" /> Tus transacciones est\303\241n seguras en DB Laragon \"parrillero\"\n                  </div>\n                </form>\n              </motion.div>\n            )}\n          </AnimatePresence>\n        </div>\n      </section>\n    </div>\n  );\n}"
        replacement_content: "  return (\n    <div className=\"min-h-screen bg-[#121212] text-[#e5e5e5]\">\n      {/* Hero Banner Section - Editorial Style */}\n      <section className=\"relative overflow-hidden border-b border-white/10 bg-[#161616] px-6 py-16 text-center md:py-24\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-red-950/10 via-transparent to-transparent pointer-events-none\" />\n        \n        <div className=\"relative mx-auto max-w-3xl\">\n          <div className=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-none bg-[#b91c1c]/10 border border-[#b91c1c]/30 text-[#b91c1c] font-mono text-xs uppercase mb-6 tracking-[0.2em] font-semibold animate-pulse\">\n            <Flame className=\"w-4 h-4 text-[#b91c1c] fill-[#b91c1c]\" /> Selecci\303\263n Boutique Chile\n          </div>\n          \n          <h1 className=\"font-serif italic text-5xl md:text-7xl text-white tracking-tight\">\n            Entre <span className=\"text-[#b91c1c]\">Parrilleros</span>\n          </h1>\n          \n          <p className=\"mt-6 text-sm md:text-base text-zinc-400 font-sans max-w-2xl mx-auto leading-relaxed tracking-wide\">\n            La pyme boutique favorita del sur de Chile. Llevamos las mejores carnes premium Angus, abarrotes artesanales y servicio parrillero directo a tu mesa en Osorno y alrededores.\n          </p>\n\n          <div className=\"flex flex-wrap justify-center gap-4 mt-10 text-[10px] uppercase tracking-widest text-zinc-500 font-semibold\">\n            <div className=\"flex items-center gap-2 bg-[#121212] px-4 py-3 border border-white/5 rounded-none\">\n              <MapPin className=\"w-3.5 h-3.5 text-[#b91c1c]\" /> Osorno Centro\n            </div>\n            <div className=\"flex items-center gap-2 bg-[#121212] px-4 py-3 border border-white/5 rounded-none\">\n              <Truck className=\"w-3.5 h-3.5 text-[#b91c1c]\" /> Despacho Express\n            </div>\n            <div className=\"flex items-center gap-2 bg-[#121212] px-4 py-3 border border-white/5 rounded-none\">\n              <Award className=\"w-3.5 h-3.5 text-[#b91c1c]\" /> Selecci\303\263n Elite\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Main Order builder */}\n      <section className=\"mx-auto max-w-7xl px-6 py-16 md:px-10 grid grid-cols-1 lg:grid-cols-12 gap-12\">\n        \n        {/* Products Column */}\n        <div className=\"lg:col-span-7\">\n          <div className=\"flex flex-col sm:flex-row sm:items-center justify-between border-b border-white/10 pb-5 mb-10 gap-4\">\n            <div>\n              <h2 className=\"text-3xl font-serif italic text-white tracking-tight\">Haz tu Pedido</h2>\n              <p className=\"text-xs text-zinc-500 mt-1 uppercase tracking-wider font-semibold\">Cortes selectos y complementos para tu fuego.</p>\n            </div>\n\n            {/* Category selection Tabs */}\n            <div className=\"flex items-center gap-1 bg-[#161616] p-1 border border-white/10 rounded-none\">\n              {([\"todos\", \"carne\", \"abarrotes\"] as const).map(cat => (\n                <button\n                  key={cat}\n                  onClick={() => setSelectedCategory(cat)}\n                  className={`px-3 py-1.5 rounded-none text-[10px] font-mono uppercase tracking-widest font-semibold transition-all ${\n                    selectedCategory === cat \n                      ? \"bg-[#b91c1c] text-white\" \n                      : \"text-zinc-500 hover:text-white\"\n                  }`}\n                  id={`cat-filter-${cat}`}\n                >\n                  {cat === \"todos\" ? \"Todo\" : cat === \"carne\" ? \"Carnes\" : \"Abarrotes\"}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Catalog grid */}\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n            {filteredProducts.map(product => {\n              const q = cart[product.id] || 0;\n              return (\n                <div \n                  key={product.id} \n                  id={`product-card-${product.id}`}\n                  className=\"group relative flex flex-col justify-between bg-[#161616] border border-white/10 rounded-none p-6 transition-all duration-300 hover:border-white/20 hover:bg-[#161616]/80\"\n                >\n                  {product.badge && (\n                    <span className=\"absolute top-4 right-4 bg-[#b91c1c] text-white text-[9px] font-mono font-semibold uppercase tracking-widest px-2 py-0.5 rounded-none border border-red-800\">\n                      {product.badge}\n                    </span>\n                  )}\n\n                  <div>\n                    <span className=\"text-4xl block mb-4 filter group-hover:scale-110 transition-transform duration-300 select-none\">\n                      {product.image}\n                    </span>\n                    \n                    <h3 className=\"font-serif italic text-lg text-white group-hover:text-[#b91c1c] transition-colors leading-snug\">\n                      {product.name}\n                    </h3>\n                    \n                    <p className=\"text-xs text-zinc-400 mt-2 line-clamp-3 leading-relaxed\">\n                      {product.description}\n                    </p>\n                  </div>\n\n                  <div className=\"flex items-center justify-between mt-6 pt-4 border-t border-white/5\">\n                    <span className=\"font-mono text-base font-semibold text-[#b91c1c]\">\n                      ${product.price.toLocaleString(\"es-CL\")}\n                    </span>\n\n                    {/* Quantity selectors */}\n                    {q > 0 ? (\n                      <div className=\"flex items-center gap-3 bg-[#121212] border border-white/10 rounded-none p-1\">\n                        <button \n                          onClick={() => updateQuantity(product.id, -1)}\n                          className=\"w-7 h-7 flex items-center justify-center rounded-none bg-zinc-800 text-zinc-300 hover:bg-red-950/45 hover:text-[#b91c1c] transition text-xs font-mono font-bold\"\n                        >\n                          -\n                        </button>\n                        <span className=\"font-mono text-xs font-bold w-4 text-center text-white\">{q}</span>\n                        <button \n                          onClick={() => updateQuantity(product.id, 1)}\n                          className=\"w-7 h-7 flex items-center justify-center rounded-none bg-zinc-800 text-zinc-300 hover:bg-green-950/40 hover:text-green-400 transition text-xs font-mono font-bold\"\n                        >\n                          +\n                        </button>\n                      </div>\n                    ) : (\n                      <button\n                        onClick={() => updateQuantity(product.id, 1)}\n                        className=\"bg-zinc-850 hover:bg-[#b91c1c] hover:border-[#b91c1c] text-zinc-300 hover:text-white font-mono uppercase tracking-[0.15em] px-4 py-2 rounded-none text-[10px] flex items-center gap-2 transition-all duration-300 border border-white/10 active:scale-95\"\n                        id={`add-to-cart-${product.id}`}\n                      >\n                        <ShoppingCart className=\"w-3.5 h-3.5\" /> Agregar\n                      </button>\n                    )}\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Form and Cart Column */}\n        <div className=\"lg:col-span-5 bg-[#161616] border border-white/10 rounded-none p-6 lg:p-8 h-fit relative\">\n          \n          <div className=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none select-none\">\n            <Flame className=\"w-48 h-48 text-[#b91c1c]\" />\n          </div>\n\n          <h3 className=\"text-xl font-serif italic text-white flex items-center gap-2 mb-6 border-b border-white/10 pb-4\">\n            <ShoppingCart className=\"w-5 h-5 text-[#b91c1c]\" /> Tu Carro Parrillero\n          </h3>\n\n          <AnimatePresence mode=\"wait\">\n            {orderSuccess ? (\n              <motion.div \n                key=\"success-card\"\n                initial={{ opacity: 0, scale: 0.98 }}\n                animate={{ opacity: 1, scale: 1 }}\n                exit={{ opacity: 0 }}\n                className=\"text-center py-6\"\n              >\n                <div className=\"w-16 h-16 bg-[#b91c1c]/10 text-[#b91c1c] rounded-none flex items-center justify-center mx-auto mb-4 border border-[#b91c1c]/35\">\n                  <CheckCircle className=\"w-10 h-10\" />\n                </div>\n                \n                <h4 className=\"text-lg font-serif italic text-[#b91c1c]\">\302\241Pedido Enviado Exitosamente!</h4>\n                <p className=\"text-xs text-zinc-400 mt-2 max-w-sm mx-auto\">\n                  La orden ha sido ingresada en la base de datos de manera permanente. \n                </p>\n\n                {/* Database logs simulated in realtime */}\n                <div className=\"bg-[#121212]/80 border border-white/10 mt-6 rounded-none p-4 text-left text-xs font-mono\">\n                  <div className=\"flex items-center gap-2 text-[#b91c1c] border-b border-white/5 pb-2 mb-2 font-semibold uppercase tracking-wider text-[10px]\">\n                    <Flame className=\"w-3.5 h-3.5 animate-pulse\" /> Logs del Servidor en Vivo:\n                  </div>\n                  \n                  <div className=\"space-y-2 text-zinc-400 leading-relaxed text-[10px]\">\n                    <p className=\"text-green-500\">\342\234\224 Guardado definitivo en Laragon MySQL exitoso.</p>\n                    <p className=\"text-zinc-500\">\360\237\224\271 ID Asignado: <span className=\"text-white font-bold\">#{orderSuccess.order?.id}</span></p>\n                    <p className=\"text-zinc-500\">\360\237\224\271 Sucursal de Despacho: {orderSuccess.order?.branch}</p>\n                    \n                    <div className=\"border-t border-white/5 pt-2 mt-2\">\n                      <p className=\"text-[#b91c1c] flex items-center gap-1 font-bold\">\n                        <Mail className=\"w-3 h-3\" /> Notificaci\303\263n por Correo:\n                      </p>\n                      <p className=\"pl-3 text-zinc-500\">{orderSuccess.notification?.email?.message}</p>\n                    </div>\n\n                    <div className=\"border-t border-white/5 pt-2\">\n                      <p className=\"text-blue-400 flex items-center gap-1 font-bold\">\n                        <Send className=\"w-3 h-3\" /> Sincronizaci\303\263n Google Sheets:\n                      </p>\n                      <p className=\"pl-3 text-zinc-500\">{orderSuccess.notification?.sheets?.message}</p>\n                    </div>\n                  </div>\n                </div>\n\n                <button\n                  onClick={() => setOrderSuccess(null)}\n                  className=\"mt-6 w-full bg-neutral-800 hover:bg-[#b91c1c] hover:text-white text-zinc-300 font-mono uppercase tracking-widest py-3 rounded-none text-xs transition font-semibold\"\n                >\n                  Armar Otro Pedido\n                </button>\n              </motion.div>\n            ) : getCartCount() === 0 ? (\n              <motion.div \n                key=\"empty-cart\"\n                initial={{ opacity: 0 }}\n                animate={{ opacity: 1 }}\n                className=\"text-center py-16 text-zinc-500\"\n              >\n                <span className=\"text-5xl block mb-3 opacity-80\">\360\237\224\245</span>\n                <p className=\"text-sm font-semibold font-serif italic text-zinc-400\">El carro est\303\241 vac\303\255o</p>\n                <p className=\"text-xs text-zinc-600 mt-1 max-w-xs mx-auto leading-relaxed\">Selecciona cortes de carne o abarrotes para pre-visualizar el monto total del asado.</p>\n              </motion.div>\n            ) : (\n              <motion.div \n                key=\"active-cart\"\n                initial={{ opacity: 0 }}\n                animate={{ opacity: 1 }}\n                exit={{ opacity: 0 }}\n              >\n                {/* List selected items */}\n                <div className=\"max-h-60 overflow-y-auto mb-6 pr-2 space-y-3 scrollbar-thin\">\n                  {MENU_ITEMS.filter(item => cart[item.id] > 0).map(item => {\n                    const count = cart[item.id];\n                    return (\n                      <div key={item.id} className=\"flex items-center justify-between bg-[#121212]/50 p-3 rounded-none border border-white/5\">\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"text-xl\">{item.image}</span>\n                          <div>\n                            <h4 className=\"text-xs font-bold text-white font-serif italic\">{item.name}</h4>\n                            <p className=\"text-[10px] text-zinc-500 mt-0.5 font-mono\">\n                              ${item.price.toLocaleString(\"es-CL\")} x {count}\n                            </p>\n                          </div>\n                        </div>\n\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"font-mono text-xs font-bold text-[#b91c1c]\">\n                            ${(item.price * count).toLocaleString(\"es-CL\")}\n                          </span>\n                          <button\n                            onClick={() => updateQuantity(item.id, -count)}\n                            className=\"text-zinc-600 hover:text-red-500 p-1 transition\"\n                            title=\"Quitar todo\"\n                          >\n                            <Trash2 className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n\n                {/* Subtotal */}\n                <div className=\"border-t border-white/10 pt-4 mb-6 space-y-2\">\n                  <div className=\"flex items-center justify-between text-xs text-zinc-500\">\n                    <span>Subtotal de Art\303\255culos</span>\n                    <span className=\"font-mono text-zinc-400\">${getCartTotal().toLocaleString(\"es-CL\")}</span>\n                  </div>\n                  <div className=\"flex items-center justify-between text-xs text-zinc-500\">\n                    <span>Despacho</span>\n                    <span className=\"text-[#b91c1c] font-semibold font-mono text-xs uppercase tracking-wider\">GRATIS</span>\n                  </div>\n                  <div className=\"flex items-center justify-between pt-2 border-t border-white/10\">\n                    <span className=\"font-semibold text-zinc-350\">Total Estimado</span>\n                    <span className=\"font-mono text-lg font-bold text-[#b91c1c]\">\n                      ${getCartTotal().toLocaleString(\"es-CL\")}\n                    </span>\n                  </div>\n                </div>\n\n                {/* Buyer Form */}\n                <form onSubmit={handleCheckout} className=\"space-y-4 pt-4 border-t border-white/10\">\n                  <h4 className=\"text-[10px] font-bold text-zinc-400 uppercase tracking-widest font-mono\">Tus Datos de Despacho</h4>\n                  \n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Nombre Completo</label>\n                    <input\n                      type=\"text\"\n                      required\n                      value={customerName}\n                      onChange={e => setCustomerName(e.target.value)}\n                      placeholder=\"Ej. Gonzalo Retamal\"\n                      className=\"w-full bg-[#121212] border border-white/10 focus:border-[#b91c1c] rounded-none px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                      id=\"input-customer-name\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Email de Contacto</label>\n                      <input\n                        type=\"email\"\n                        required\n                        value={email}\n                        onChange={e => setEmail(e.target.value)}\n                        placeholder=\"Ej. gonzalo@gmail.com\"\n                        className=\"w-full bg-[#121212] border border-white/10 focus:border-[#b91c1c] rounded-none px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"input-customer-email\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">WhatsApp / Celular</label>\n                      <input\n                        type=\"text\"\n                        required\n                        value={phone}\n                        onChange={e => setPhone(e.target.value)}\n                        placeholder=\"Ej. +56982731192\"\n                        className=\"w-full bg-[#121212] border border-white/10 focus:border-[#b91c1c] rounded-none px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"input-customer-phone\"\n                      />\n                    </div>\n                  </div>\n\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Sucursal Asociada</label>\n                      <select\n                        value={branch}\n                        onChange={e => setBranch(e.target.value)}\n                        className=\"w-full bg-[#121212] border border-white/10 focus:border-[#b91c1c] rounded-none px-3 py-2 text-xs text-neutral-100 outline-none transition\"\n                        id=\"select-customer-branch\"\n                      >\n                        <option value=\"Osorno Centro\">Osorno Centro</option>\n                        <option value=\"Santiago Providencia\">Santiago Providencia</option>\n                        <option value=\"Valdivia Costanera\">Valdivia Costanera</option>\n                      </select>\n                    </div>\n\n                    <div>\n                      <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">V\303\255a de Recepci\303\263n</label>\n                      <div className=\"w-full bg-[#121212]/50 border border-white/10 font-semibold rounded-none px-3 py-2 text-xs text-[#b91c1c] flex items-center gap-2\">\n                        <Truck className=\"w-3.5 h-3.5 text-[#b91c1c]\" /> Despacho a Domicilio\n                      </div>\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[10px] uppercase font-mono tracking-wider text-zinc-500 font-bold mb-1\">Comentarios / Indicaci\303\263n de Corte</label>\n                    <textarea\n                      value={notes}\n                      onChange={e => setNotes(e.target.value)}\n                      placeholder=\"Ej. Prefiero el lomo vetado en un solo trozo / Entregar despu\303\251s de las 18:00 hrs.\"\n                      rows={2}\n                      className=\"w-full bg-[#121212] border border-white/10 focus:border-[#b91c1c] rounded-none px-3 py-2 text-xs text-neutral-100 outline-none transition resize-none\"\n                    />\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    disabled={isSubmitting}\n                    className=\"w-full bg-[#b91c1c] hover:bg-red-700 disabled:bg-zinc-800 text-white font-mono uppercase tracking-widest py-3 px-4 rounded-none flex items-center justify-center gap-2 transition duration-300 transform active:scale-95 text-xs font-semibold select-none cursor-pointer\"\n                    id=\"submit-order-checkout\"\n                  >\n                    {isSubmitting ? (\n                      <>Procesando Solicitud...</>\n                    ) : (\n                      <>\n                        <Flame className=\"w-4 h-4 fill-white\" /> Confirmar Pedido Parrillero (${getCartTotal().toLocaleString(\"es-CL\")})\n                      </>\n                    )}\n                  </button>\n\n                  <div className=\"flex items-center justify-center gap-2 text-[10px] text-zinc-500 pb-2\">\n                    <ShieldCheck className=\"w-3.5 h-3.5 text-[#b91c1c]\" /> Tus transacciones est\303\241n seguras en DB Laragon \"parrillero\"\n                  </div>\n                </form>\n              </motion.div>\n            )}\n          </AnimatePresence>\n        </div>\n      </section>\n    </div>\n  );\n}"
      }
      num_matches: 1
    }
  }
}
